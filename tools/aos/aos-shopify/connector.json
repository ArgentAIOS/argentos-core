{
  "tool": "aos-shopify",
  "backend": "shopify-admin",
  "manifest_schema_version": "1.0.0",
  "connector": {
    "label": "Shopify",
    "category": "commerce-ops",
    "categories": ["commerce-ops", "orders", "inventory"],
    "resources": ["shop", "product", "order", "customer", "fulfillment"]
  },
  "scope": {
    "kind": "store-catalog",
    "summary": "Scope Shopify workers by store, catalog status, order status, customer email, and created date window.",
    "fields": [
      {
        "id": "shop_domain",
        "label": "Shop domain",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "shop.read",
          "product.list",
          "product.read",
          "order.list",
          "order.read",
          "customer.list",
          "customer.read"
        ],
        "example": "example.myshopify.com",
        "placeholder": "mystore.myshopify.com",
        "description": "Your Shopify store domain."
      },
      {
        "id": "product_status",
        "label": "Product status",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["product.list"],
        "example": "active, draft, archived, any",
        "options": [
          { "value": "active", "label": "Active" },
          { "value": "draft", "label": "Draft" },
          { "value": "archived", "label": "Archived" },
          { "value": "any", "label": "Any" }
        ],
        "placeholder": "Select status...",
        "description": "Filter products by status."
      },
      {
        "id": "order_status",
        "label": "Order status",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["order.list"],
        "example": "open, closed, cancelled, any",
        "options": [
          { "value": "open", "label": "Open" },
          { "value": "closed", "label": "Closed" },
          { "value": "cancelled", "label": "Cancelled" },
          { "value": "any", "label": "Any" }
        ],
        "placeholder": "Select status...",
        "description": "Filter orders by status."
      },
      {
        "id": "customer_email",
        "label": "Customer email",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["customer.list"],
        "example": "vip@example.com",
        "placeholder": "customer@example.com",
        "description": "Filter customers by email address."
      },
      {
        "id": "created_after",
        "label": "Created after",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["order.list", "customer.list"],
        "example": "2026-01-01 or 1704067200",
        "placeholder": "2026-01-01",
        "description": "Filter records created after this date (ISO 8601 or Unix timestamp)."
      },
      {
        "id": "created_before",
        "label": "Created before",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["order.list", "customer.list"],
        "example": "2026-01-31 or 1706745600",
        "placeholder": "2026-01-31",
        "description": "Filter records created before this date (ISO 8601 or Unix timestamp)."
      }
    ],
    "command_defaults": {
      "product.list": {
        "status_env": "SHOPIFY_PRODUCT_STATUS"
      },
      "order.list": {
        "status_env": "SHOPIFY_ORDER_STATUS",
        "created_after_env": "SHOPIFY_CREATED_AFTER",
        "created_before_env": "SHOPIFY_CREATED_BEFORE"
      },
      "customer.list": {
        "email_env": "SHOPIFY_CUSTOMER_EMAIL",
        "created_after_env": "SHOPIFY_CREATED_AFTER",
        "created_before_env": "SHOPIFY_CREATED_BEFORE"
      }
    }
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["SHOPIFY_SHOP_DOMAIN", "SHOPIFY_ADMIN_ACCESS_TOKEN"],
    "interactive_setup": [
      "Create a Shopify custom app for the target store.",
      "Add SHOPIFY_SHOP_DOMAIN and SHOPIFY_ADMIN_ACCESS_TOKEN in API Keys.",
      "Grant the read scopes needed for products, orders, and customers before enabling any worker-visible actions.",
      "Keep write scopes disabled until a live mutation bridge is implemented and reviewed."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "shop.read",
      "summary": "Read Shopify shop setup metadata",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "shop",
      "action_class": "read"
    },
    {
      "id": "product.list",
      "summary": "List Shopify products",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "product",
      "action_class": "read"
    },
    {
      "id": "product.read",
      "summary": "Read a Shopify product",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "product",
      "action_class": "read"
    },
    {
      "id": "product.update",
      "summary": "Update a Shopify product",
      "required_mode": "write",
      "supports_json": true,
      "resource": "product",
      "action_class": "write"
    },
    {
      "id": "order.list",
      "summary": "List Shopify orders",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "order.read",
      "summary": "Read a Shopify order",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "order.cancel",
      "summary": "Cancel a Shopify order",
      "required_mode": "full",
      "supports_json": true,
      "resource": "order",
      "action_class": "write"
    },
    {
      "id": "customer.list",
      "summary": "List Shopify customers",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.read",
      "summary": "Read a Shopify customer",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "fulfillment.create",
      "summary": "Create a Shopify fulfillment",
      "required_mode": "write",
      "supports_json": true,
      "resource": "fulfillment",
      "action_class": "write"
    }
  ],
  "events": [
    {
      "id": "order.created",
      "resource": "order",
      "summary": "New order placed in the store",
      "delivery": "webhook",
      "configFields": [
        {
          "id": "event_min_amount",
          "label": "Minimum Order Amount",
          "type": "number",
          "renderAs": "number",
          "required": false,
          "placeholder": "5000",
          "description": "Only trigger for orders above this amount (in store currency, cents). Leave empty for all orders."
        }
      ]
    },
    {
      "id": "product.updated",
      "resource": "product",
      "summary": "Product details or variants updated",
      "delivery": "webhook",
      "configFields": [
        {
          "id": "event_collection_filter",
          "label": "Collection Filter",
          "type": "text",
          "renderAs": "text",
          "required": false,
          "placeholder": "Summer Sale",
          "description": "Only trigger for products in this collection. Leave empty for all products."
        }
      ]
    },
    {
      "id": "checkout.completed",
      "resource": "order",
      "summary": "Checkout completed by a customer",
      "delivery": "webhook",
      "configFields": [
        {
          "id": "event_source_filter",
          "label": "Source Filter",
          "type": "select",
          "renderAs": "select",
          "required": false,
          "options": [
            { "value": "web", "label": "Online Store" },
            { "value": "pos", "label": "Point of Sale" },
            { "value": "shopify_draft_order", "label": "Draft Order" },
            { "value": "iphone", "label": "iPhone App" },
            { "value": "android", "label": "Android App" }
          ],
          "description": "Only trigger for checkouts from this source. Leave empty for all sources."
        }
      ]
    }
  ]
}
