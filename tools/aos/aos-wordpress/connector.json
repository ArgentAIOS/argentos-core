{
  "backend": "wordpress-rest-api",
  "connector": {
    "label": "WordPress",
    "category": "marketing-publishing",
    "categories": ["marketing-publishing", "knowledge-docs", "web-content"],
    "resources": ["site", "post", "page", "media", "taxonomy"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["WORDPRESS_BASE_URL", "WORDPRESS_USERNAME", "WORDPRESS_APPLICATION_PASSWORD"],
    "interactive_setup": [
      "Create a dedicated WordPress service user on the target site.",
      "Generate an Application Password for that user.",
      "Add WORDPRESS_BASE_URL, WORDPRESS_USERNAME, and WORDPRESS_APPLICATION_PASSWORD in API Keys.",
      "Restrict post types, status transitions, taxonomy scope, and media usage before going live."
    ]
  },
  "fields": {
    "site_url": {
      "label": "WordPress Site URL",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": false,
      "valueType": "string",
      "description": "Base URL of the WordPress site.",
      "placeholder": "https://example.com",
      "required_for": ["site.read"]
    },
    "post_id": {
      "label": "Post ID",
      "type": "number",
      "renderAs": "number",
      "expressionEnabled": true,
      "valueType": "number",
      "description": "WordPress post ID for read, update, schedule, publish, or taxonomy assignment.",
      "placeholder": "123",
      "required_for": ["post.read", "post.update_draft", "post.publish"]
    },
    "page_id": {
      "label": "Page ID",
      "type": "number",
      "renderAs": "number",
      "expressionEnabled": true,
      "valueType": "number",
      "description": "WordPress page ID for read, update, publish, or taxonomy assignment.",
      "placeholder": "456",
      "required_for": ["page.read", "page.update_draft", "page.publish"]
    },
    "title": {
      "label": "Title",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Title for draft or scheduled content.",
      "placeholder": "Launch notes",
      "required_for": ["post.create_draft", "page.create_draft"]
    },
    "content": {
      "label": "Content",
      "type": "string",
      "renderAs": "richtext",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "HTML or block content body.",
      "placeholder": "<p>Content here</p>"
    },
    "excerpt": {
      "label": "Excerpt",
      "type": "string",
      "renderAs": "textarea",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Optional post or page excerpt."
    },
    "slug": {
      "label": "Slug",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Optional URL slug.",
      "placeholder": "launch-notes"
    },
    "publish_at": {
      "label": "Publish At",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "RFC3339 date/time for scheduled posts.",
      "placeholder": "2026-05-01T15:00:00Z",
      "required_for": ["post.schedule"]
    },
    "search_query": {
      "label": "Search Query",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Search term for post, page, media, or taxonomy listing.",
      "placeholder": "release"
    },
    "status": {
      "label": "Status Filter",
      "type": "string",
      "renderAs": "select",
      "expressionEnabled": false,
      "valueType": "string",
      "options": [
        { "value": "draft", "label": "Draft" },
        { "value": "publish", "label": "Published" },
        { "value": "pending", "label": "Pending Review" },
        { "value": "future", "label": "Scheduled" },
        { "value": "private", "label": "Private" }
      ],
      "description": "Optional status filter for post and page list/search commands."
    },
    "per_page": {
      "label": "Per Page",
      "type": "number",
      "renderAs": "number",
      "expressionEnabled": true,
      "valueType": "number",
      "description": "Number of results per page.",
      "placeholder": "10",
      "default": 10
    },
    "media_file": {
      "label": "Media File",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Local file path for media upload.",
      "placeholder": "/path/to/image.jpg",
      "required_for": ["media.upload"]
    },
    "media_type": {
      "label": "Media Type",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Optional media type filter such as image or file.",
      "placeholder": "image"
    },
    "mime_type": {
      "label": "MIME Type",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Optional MIME type filter or upload content type.",
      "placeholder": "image/jpeg"
    },
    "category_ids": {
      "label": "Category IDs",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Comma-separated category IDs for taxonomy assignment.",
      "placeholder": "3,4",
      "required_for": ["taxonomy.assign_terms"]
    },
    "tag_ids": {
      "label": "Tag IDs",
      "type": "string",
      "renderAs": "text",
      "expressionEnabled": true,
      "valueType": "string",
      "description": "Comma-separated tag IDs for taxonomy assignment.",
      "placeholder": "5,8",
      "required_for": ["taxonomy.assign_terms"]
    }
  },
  "worker_visible_actions": [
    "site.read",
    "post.list",
    "post.search",
    "post.read",
    "post.create_draft",
    "post.update_draft",
    "post.schedule",
    "post.publish",
    "page.list",
    "page.search",
    "page.read",
    "page.create_draft",
    "page.update_draft",
    "page.publish",
    "media.list",
    "media.upload",
    "taxonomy.list",
    "taxonomy.assign_terms"
  ],
  "commands": [
    {
      "id": "health",
      "summary": "Check WordPress connectivity and auth readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "site",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run a detailed WordPress runtime diagnosis",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "site",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted WordPress connector config",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "site",
      "action_class": "read"
    },
    {
      "id": "site.read",
      "summary": "Read WordPress site info",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "site",
      "action_class": "read"
    },
    {
      "id": "post.list",
      "summary": "List posts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    },
    {
      "id": "post.search",
      "summary": "Search posts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    },
    {
      "id": "post.read",
      "summary": "Read a post",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    },
    {
      "id": "post.create_draft",
      "summary": "Create a draft post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "post.update_draft",
      "summary": "Update a draft post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "post.schedule",
      "summary": "Schedule a post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "post.publish",
      "summary": "Publish an approved post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "page.list",
      "summary": "List pages",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "page.search",
      "summary": "Search pages",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "page.read",
      "summary": "Read a page",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "page.create_draft",
      "summary": "Create a draft page",
      "required_mode": "write",
      "supports_json": true,
      "resource": "page",
      "action_class": "write"
    },
    {
      "id": "page.update_draft",
      "summary": "Update a draft page",
      "required_mode": "write",
      "supports_json": true,
      "resource": "page",
      "action_class": "write"
    },
    {
      "id": "page.publish",
      "summary": "Publish an approved page",
      "required_mode": "write",
      "supports_json": true,
      "resource": "page",
      "action_class": "write"
    },
    {
      "id": "media.list",
      "summary": "List media items",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "media",
      "action_class": "read"
    },
    {
      "id": "media.upload",
      "summary": "Upload a media item",
      "required_mode": "write",
      "supports_json": true,
      "resource": "media",
      "action_class": "write"
    },
    {
      "id": "taxonomy.list",
      "summary": "List categories and tags",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "taxonomy",
      "action_class": "read"
    },
    {
      "id": "taxonomy.assign_terms",
      "summary": "Assign categories or tags",
      "required_mode": "write",
      "supports_json": true,
      "resource": "taxonomy",
      "action_class": "write"
    }
  ]
}
