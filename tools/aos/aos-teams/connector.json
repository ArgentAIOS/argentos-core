{
  "tool": "aos-teams",
  "backend": "microsoft-graph",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "communication",
    "surface": "team-channel-meeting",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": [
      "team_id",
      "channel_display_name",
      "channel_description",
      "user_id",
      "meeting_subject",
      "start_time",
      "end_time"
    ],
    "worker_visible_actions": [
      "team.list",
      "channel.list",
      "channel.create",
      "meeting.list",
      "meeting.create"
    ],
    "fields": [
      {
        "id": "team_id",
        "label": "Team ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["channel.list", "channel.create"],
        "placeholder": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "description": "The Microsoft Teams team UUID to operate in. Required for channel listing and channel creation."
      },
      {
        "id": "channel_display_name",
        "label": "Channel name",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["channel.create"],
        "placeholder": "Release coordination",
        "description": "Display name for the new Teams channel."
      },
      {
        "id": "channel_description",
        "label": "Channel description",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["channel.create"],
        "placeholder": "Channel for release coordination",
        "description": "Optional description for the new Teams channel."
      },
      {
        "id": "user_id",
        "label": "Target user ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["meeting.list", "meeting.create"],
        "placeholder": "7f7c0e9c-0dcb-4f19-9cc0-1d2a3b4c5d6e",
        "description": "Microsoft Entra user object ID used for meeting reads and application-policy-backed meeting creation."
      },
      {
        "id": "meeting_subject",
        "label": "Meeting subject",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["meeting.create"],
        "placeholder": "Weekly standup",
        "description": "The subject line for the Teams meeting to create."
      },
      {
        "id": "start_time",
        "label": "Meeting start time (ISO 8601)",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["meeting.create"],
        "placeholder": "2026-04-01T10:00:00-05:00",
        "description": "Meeting start time in ISO 8601 format with timezone (e.g. 2026-04-01T10:00:00-05:00)."
      },
      {
        "id": "end_time",
        "label": "Meeting end time (ISO 8601)",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["meeting.create"],
        "placeholder": "2026-04-01T10:30:00-05:00",
        "description": "Optional ISO 8601 end time. When omitted, the harness defaults the meeting to 30 minutes."
      }
    ],
    "commandDefaults": {
      "team.list": {
        "selection_surface": "team",
        "limit": 20
      },
      "channel.list": {
        "selection_surface": "channel",
        "args": ["TEAMS_TEAM_ID"],
        "limit": 20
      },
      "channel.create": {
        "selection_surface": "channel",
        "args": ["TEAMS_TEAM_ID"]
      },
      "meeting.list": {
        "selection_surface": "meeting",
        "args": ["TEAMS_USER_ID"],
        "limit": 10
      },
      "meeting.create": {
        "selection_surface": "meeting",
        "args": ["TEAMS_USER_ID"]
      }
    },
    "pickerHints": {
      "team": {
        "kind": "team",
        "selection_surface": "team",
        "resource": "teams.team",
        "source_command": "team.list",
        "source_fields": ["id", "displayName", "description", "visibility"]
      },
      "channel": {
        "kind": "channel",
        "selection_surface": "channel",
        "resource": "teams.channel",
        "source_command": "channel.list",
        "source_fields": ["id", "displayName", "description", "membershipType"]
      },
      "meeting": {
        "kind": "meeting",
        "selection_surface": "meeting",
        "resource": "teams.meeting",
        "source_command": "meeting.list",
        "source_fields": ["id", "subject", "startDateTime", "endDateTime", "joinUrl"]
      }
    }
  },
  "connector": {
    "label": "Microsoft Teams",
    "category": "communication",
    "categories": ["communication", "messaging", "collaboration", "workflow-automation"],
    "resources": ["team", "channel", "meeting"]
  },
  "auth": {
    "kind": "oauth-service-key",
    "required": true,
    "service_keys": ["TEAMS_TENANT_ID", "TEAMS_CLIENT_ID", "TEAMS_CLIENT_SECRET"],
    "interactive_setup": [
      "Register an application in Microsoft Entra ID (Azure AD).",
      "Grant only the Microsoft Graph application permissions needed for the surfaced commands: GroupMember.Read.All (team.list), ChannelSettings.Read.Group or Channel.ReadBasic.All (channel.list), Channel.Create.Group or Channel.Create (channel.create), Calendars.ReadBasic or Calendars.Read (meeting.list), and OnlineMeetings.ReadWrite.All plus an application access policy for the scoped user (meeting.create).",
      "Add TEAMS_TENANT_ID, TEAMS_CLIENT_ID, and TEAMS_CLIENT_SECRET in operator-controlled API Keys first.",
      "When TEAMS_TEAM_ID or TEAMS_USER_ID are used as worker-linking defaults, store them in operator-controlled service keys first and use local environment variables only as a harness fallback.",
      "Set TEAMS_TEAM_ID to give channel commands a stable default team scope.",
      "Set TEAMS_USER_ID to the target user's Microsoft Entra object ID before running meeting.list or meeting.create."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and backend readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "team.list",
      "summary": "List Microsoft Teams teams accessible to the app",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "channel.list",
      "summary": "List channels in a Teams team",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "channel",
      "action_class": "read"
    },
    {
      "id": "channel.create",
      "summary": "Create a new channel in a Teams team",
      "required_mode": "write",
      "supports_json": true,
      "resource": "channel",
      "action_class": "write"
    },
    {
      "id": "meeting.list",
      "summary": "List upcoming Teams meetings",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "meeting",
      "action_class": "read"
    },
    {
      "id": "meeting.create",
      "summary": "Create an online Teams meeting for a scoped user",
      "required_mode": "write",
      "supports_json": true,
      "resource": "meeting",
      "action_class": "write"
    }
  ]
}
