{
  "tool": "aos-square",
  "backend": "square-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "commerce",
    "surface": "payment-customer-order-item-invoice-location",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": [
      "location_id",
      "customer_id",
      "order_id",
      "payment_id",
      "item_id"
    ],
    "worker_visible_actions": [
      "payment.list",
      "payment.get",
      "customer.list",
      "customer.get",
      "order.list",
      "order.get",
      "item.list",
      "item.get",
      "invoice.list",
      "location.list"
    ],
    "fields": [
      {
        "id": "location_id",
        "label": "Location ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "payment.list",
          "order.list",
          "invoice.list"
        ],
        "example": "L1BQFNKJ0AB1C",
        "placeholder": "Select location...",
        "description": "The Square location to scope read operations."
      },
      {
        "id": "customer_id",
        "label": "Customer ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "customer.get"
        ],
        "example": "JDKYHBWT1D4F8MFH63DBMEN8Y4",
        "placeholder": "Select customer...",
        "description": "The Square customer ID."
      },
      {
        "id": "order_id",
        "label": "Order ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "order.get"
        ],
        "example": "CAISENgvlJ6jLWAzERDzjyHVREo",
        "placeholder": "e.g., CAISENgvlJ6jLWAzERDzjyHVREo",
        "description": "The Square order ID."
      },
      {
        "id": "payment_id",
        "label": "Payment ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "payment.get"
        ],
        "example": "PAYMENT_ID",
        "placeholder": "e.g., PAYMENT_ID",
        "description": "The Square payment ID."
      },
      {
        "id": "item_id",
        "label": "Item ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "item.get"
        ],
        "example": "ITEM_ID",
        "placeholder": "e.g., ITEM_ID",
        "description": "The Square catalog item ID."
      }
    ],
    "commandDefaults": {
      "payment.list": {
        "selection_surface": "payment",
        "args": [
          "SQUARE_LOCATION_ID"
        ],
        "limit": 10
      },
      "payment.get": {
        "selection_surface": "payment",
        "args": [
          "SQUARE_PAYMENT_ID"
        ]
      },
      "customer.list": {
        "selection_surface": "customer",
        "limit": 10
      },
      "customer.get": {
        "selection_surface": "customer",
        "args": [
          "SQUARE_CUSTOMER_ID"
        ]
      },
      "order.list": {
        "selection_surface": "order",
        "args": [
          "SQUARE_LOCATION_ID"
        ],
        "limit": 10
      },
      "order.get": {
        "selection_surface": "order",
        "args": [
          "SQUARE_ORDER_ID"
        ]
      },
      "item.list": {
        "selection_surface": "item",
        "limit": 10
      },
      "item.get": {
        "selection_surface": "item",
        "args": [
          "SQUARE_ITEM_ID"
        ]
      },
      "invoice.list": {
        "selection_surface": "invoice",
        "args": [
          "SQUARE_LOCATION_ID"
        ],
        "limit": 10
      },
      "location.list": {
        "selection_surface": "location",
        "limit": 10
      }
    },
    "pickerHints": {
      "payment": {
        "kind": "payment",
        "selection_surface": "payment",
        "resource": "square.payment",
        "source_command": "payment.list",
        "source_fields": [
          "id",
          "amount_money",
          "status",
          "source_type",
          "created_at",
          "order_id"
        ]
      },
      "customer": {
        "kind": "customer",
        "selection_surface": "customer",
        "resource": "square.customer",
        "source_command": "customer.list",
        "source_fields": [
          "id",
          "given_name",
          "family_name",
          "email_address",
          "created_at"
        ]
      },
      "order": {
        "kind": "order",
        "selection_surface": "order",
        "resource": "square.order",
        "source_command": "order.list",
        "source_fields": [
          "id",
          "state",
          "total_money",
          "created_at",
          "line_items"
        ]
      },
      "item": {
        "kind": "item",
        "selection_surface": "item",
        "resource": "square.item",
        "source_command": "item.list",
        "source_fields": [
          "id",
          "name",
          "type",
          "variations",
          "updated_at"
        ]
      },
      "invoice": {
        "kind": "invoice",
        "selection_surface": "invoice",
        "resource": "square.invoice",
        "source_command": "invoice.list",
        "source_fields": [
          "id",
          "status",
          "invoice_number",
          "payment_requests",
          "created_at"
        ]
      },
      "location": {
        "kind": "location",
        "selection_surface": "location",
        "resource": "square.location",
        "source_command": "location.list",
        "source_fields": [
          "id",
          "name",
          "address",
          "status",
          "timezone",
          "currency"
        ]
      }
    }
  },
  "connector": {
    "label": "Square",
    "category": "commerce-ops",
    "categories": [
      "commerce-ops",
      "payments",
      "invoicing",
      "crm-revenue"
    ],
    "resources": [
      "payment",
      "customer",
      "order",
      "item",
      "invoice",
      "location"
    ]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": [
      "SQUARE_ACCESS_TOKEN",
      "SQUARE_ENVIRONMENT",
      "SQUARE_LOCATION_ID",
      "SQUARE_CUSTOMER_ID",
      "SQUARE_ORDER_ID",
      "SQUARE_PAYMENT_ID",
      "SQUARE_ITEM_ID"
    ],
    "interactive_setup": [
      "Create a Square application at https://developer.squareup.com/apps and generate an access token.",
      "Add SQUARE_ACCESS_TOKEN in operator-controlled API Keys before enabling live reads.",
      "The harness resolves SQUARE_ACCESS_TOKEN and Square linking keys from service keys first, then falls back to process.env only for local development.",
      "Optionally set SQUARE_ENVIRONMENT to 'sandbox' in operator-controlled service keys for testing (defaults to 'production').",
      "Set SQUARE_LOCATION_ID in operator-controlled service keys to pin a default location for payment, order, and invoice scoping.",
      "No Square write command is advertised until live write workflows and approval policy are implemented.",
      "The connector is live-read-first and will report API failures instead of masking them."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and Square API readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "payment.list",
      "summary": "List Square payments",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "payment.get",
      "summary": "Get a Square payment",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "customer.list",
      "summary": "List Square customers",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.get",
      "summary": "Get a Square customer",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "order.list",
      "summary": "List Square orders",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "order.get",
      "summary": "Get a Square order",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "item.list",
      "summary": "List Square catalog items",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "item",
      "action_class": "read"
    },
    {
      "id": "item.get",
      "summary": "Get a Square catalog item",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "item",
      "action_class": "read"
    },
    {
      "id": "invoice.list",
      "summary": "List Square invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "location.list",
      "summary": "List Square locations",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "location",
      "action_class": "read"
    }
  ]
}
