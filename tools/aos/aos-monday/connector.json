{
  "tool": "aos-monday",
  "backend": "monday-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "work-management",
    "surface": "board-item-update",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "live_write_smoke_tested": false,
    "workerFields": ["workspace_id", "board_id", "item_id", "column_id"],
    "worker_visible_actions": [
      "workspace.list",
      "board.list",
      "board.read",
      "item.read",
      "item.create",
      "item.update",
      "update.list",
      "update.create"
    ],
    "fields": [
      {
        "id": "workspace_id",
        "label": "Workspace",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select workspace...",
        "description": "Monday workspace to operate in; may default from operator service key MONDAY_WORKSPACE_ID."
      },
      {
        "id": "board_id",
        "label": "Board",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select board...",
        "description": "Monday board ID to operate on; may default from operator service key MONDAY_BOARD_ID."
      },
      {
        "id": "item_id",
        "label": "Item",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select item...",
        "description": "Monday item ID to operate on; may default from operator service key MONDAY_ITEM_ID."
      },
      {
        "id": "item_name",
        "label": "Item Name",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["item.create", "item.update"],
        "placeholder": "Enter item name...",
        "description": "Name of the item to create or update"
      },
      {
        "id": "column_id",
        "label": "Column",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select column...",
        "description": "Monday column ID for status or field updates; may default from operator service key MONDAY_COLUMN_ID."
      },
      {
        "id": "column_value",
        "label": "Column Value",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["item.update"],
        "placeholder": "Enter value...",
        "description": "Value to set in the specified column"
      }
    ],
    "commandDefaults": {
      "account.read": {
        "selection_surface": "account"
      },
      "workspace.list": {
        "selection_surface": "workspace"
      },
      "board.list": {
        "selection_surface": "board"
      },
      "board.read": {
        "selection_surface": "board",
        "args": ["MONDAY_BOARD_ID"]
      },
      "item.read": {
        "selection_surface": "item",
        "args": ["MONDAY_ITEM_ID"]
      },
      "item.create": {
        "selection_surface": "item",
        "args": ["MONDAY_BOARD_ID"]
      },
      "item.update": {
        "selection_surface": "item",
        "args": ["MONDAY_ITEM_ID", "MONDAY_BOARD_ID", "MONDAY_COLUMN_ID"]
      },
      "update.list": {
        "selection_surface": "update"
      },
      "update.create": {
        "selection_surface": "update",
        "args": ["MONDAY_ITEM_ID"]
      }
    }
  },
  "connector": {
    "label": "Monday.com",
    "category": "productivity-suite",
    "categories": ["productivity-suite", "project-management", "work-management"],
    "resources": ["account", "board", "workspace", "item", "update"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["MONDAY_TOKEN"],
    "optional_scope_service_keys": [
      "MONDAY_API_URL",
      "MONDAY_API_VERSION",
      "MONDAY_WORKSPACE_ID",
      "MONDAY_BOARD_ID",
      "MONDAY_ITEM_ID",
      "MONDAY_COLUMN_ID"
    ],
    "interactive_setup": [
      "Create or copy a monday.com personal API token from the Developer Center.",
      "Add MONDAY_TOKEN in operator-controlled service keys before enabling worker-visible commands.",
      "Optionally set MONDAY_API_URL and MONDAY_API_VERSION as operator-controlled service keys for endpoint/version pinning.",
      "Optionally set MONDAY_WORKSPACE_ID, MONDAY_BOARD_ID, MONDAY_ITEM_ID, and MONDAY_COLUMN_ID as operator-controlled scope defaults.",
      "Share the boards and workspaces you want this worker to read with the account that owns the token.",
      "Read commands and consequential write commands are live GraphQL operations; writes require write mode or higher."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and backend readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "account.read",
      "summary": "Read the authenticated monday account",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "workspace.list",
      "summary": "List monday workspaces",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "workspace",
      "action_class": "read"
    },
    {
      "id": "board.list",
      "summary": "List monday boards",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "board",
      "action_class": "read"
    },
    {
      "id": "board.read",
      "summary": "Read a monday board with item and update previews",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "board",
      "action_class": "read"
    },
    {
      "id": "item.read",
      "summary": "Read a monday item",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "item",
      "action_class": "read"
    },
    {
      "id": "update.list",
      "summary": "List monday updates",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "update",
      "action_class": "read"
    },
    {
      "id": "item.create",
      "summary": "Create a monday item",
      "required_mode": "write",
      "supports_json": true,
      "resource": "item",
      "action_class": "write"
    },
    {
      "id": "item.update",
      "summary": "Update a monday item",
      "required_mode": "write",
      "supports_json": true,
      "resource": "item",
      "action_class": "write"
    },
    {
      "id": "update.create",
      "summary": "Create a monday update",
      "required_mode": "write",
      "supports_json": true,
      "resource": "update",
      "action_class": "write"
    }
  ]
}
