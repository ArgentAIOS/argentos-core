{
  "tool": "aos-make",
  "backend": "make-live-bridge",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "make-live-bridge",
    "surface": "scenario",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "live_write_available": true,
    "write_bridge_available": true,
    "live_write_smoke_tested": false,
    "required": ["MAKE_API_URL", "MAKE_API_KEY"],
    "optional": [
      "MAKE_WEBHOOK_BASE_URL",
      "MAKE_ORGANIZATION_ID",
      "MAKE_ORGANIZATION_NAME",
      "MAKE_TEAM_ID",
      "MAKE_TEAM_NAME",
      "MAKE_SCENARIO_ID",
      "MAKE_SCENARIO_NAME",
      "MAKE_SCENARIO_STATUS",
      "MAKE_CONNECTION_ID",
      "MAKE_CONNECTION_NAME",
      "MAKE_EXECUTION_ID",
      "MAKE_RUN_ID"
    ],
    "worker_visible_actions": [
      "organization.list",
      "team.list",
      "scenario.list",
      "scenario.status",
      "connection.list",
      "execution.list",
      "execution.status",
      "scenario.trigger",
      "execution.run"
    ],
    "workerFields": ["scenario_id", "scenario_name", "event", "payload", "active"],
    "fields": [
      {
        "id": "scenario_id",
        "label": "Scenario ID",
        "type": "string",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Make scenario ID to target",
        "placeholder": "54321",
        "applies_to": ["scenario.status", "scenario.trigger", "execution.run"]
      },
      {
        "id": "scenario_name",
        "label": "Scenario Name",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Scenario name for display and filtering",
        "placeholder": "my-scenario",
        "applies_to": ["scenario.list", "scenario.trigger"]
      },
      {
        "id": "event",
        "label": "Event Type",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Type of event triggering the scenario",
        "options": [
          { "value": "manual", "label": "Manual Trigger" },
          { "value": "webhook", "label": "Webhook" },
          { "value": "scheduled", "label": "Scheduled" },
          { "value": "replay", "label": "Replay" },
          { "value": "custom", "label": "Custom" }
        ],
        "default": "manual",
        "applies_to": ["scenario.trigger", "execution.run"]
      },
      {
        "id": "payload",
        "label": "Trigger Payload",
        "type": "json",
        "renderAs": "json",
        "required": false,
        "expressionEnabled": true,
        "valueType": "json",
        "description": "JSON payload data to pass to the scenario",
        "placeholder": "{\"source\": \"agent\", \"reason\": \"follow-up\"}",
        "applies_to": ["scenario.trigger", "execution.run"]
      },
      {
        "id": "active",
        "label": "Activate Scenario",
        "type": "boolean",
        "renderAs": "boolean",
        "required": false,
        "expressionEnabled": false,
        "valueType": "boolean",
        "description": "Automatically activate scenario after trigger",
        "default": true,
        "applies_to": ["scenario.trigger"]
      }
    ],
    "commandDefaults": {
      "organization.list": {
        "selection_surface": "organization",
        "limit": 10
      },
      "team.list": {
        "selection_surface": "team",
        "limit": 10
      },
      "scenario.list": {
        "selection_surface": "scenario",
        "limit": 10,
        "status": "active"
      },
      "scenario.status": {
        "selection_surface": "scenario"
      },
      "connection.list": {
        "selection_surface": "connection",
        "limit": 10
      },
      "execution.list": {
        "selection_surface": "execution",
        "limit": 10
      },
      "execution.status": {
        "selection_surface": "execution"
      },
      "scenario.trigger": {
        "selection_surface": "scenario",
        "event": "manual",
        "payload_mode": "key_value_pairs_or_json",
        "event_hints": ["manual", "webhook", "scheduled", "replay", "custom"],
        "payload_example": {
          "source": "agent",
          "reason": "manual"
        }
      },
      "execution.run": {
        "selection_surface": "scenario",
        "event": "manual",
        "payload_mode": "key_value_pairs_or_json",
        "event_hints": ["manual", "webhook", "scheduled", "replay", "custom"],
        "payload_example": {
          "source": "agent",
          "reason": "manual"
        }
      }
    },
    "pickerHints": {
      "organization": {
        "kind": "organization",
        "selection_surface": "organization",
        "resource": "organization",
        "source_fields": ["organization_id", "organization_name", "organization_status"]
      },
      "team": {
        "kind": "team",
        "selection_surface": "team",
        "resource": "team",
        "source_fields": ["team_id", "team_name", "organization_name"]
      },
      "scenario": {
        "kind": "scenario",
        "selection_surface": "scenario",
        "resource": "scenario",
        "source_fields": ["scenario_id", "scenario_name", "scenario_status"]
      },
      "connection": {
        "kind": "connection",
        "selection_surface": "connection",
        "resource": "connection",
        "source_fields": ["connection_id", "connection_name", "connection_status"]
      },
      "execution": {
        "kind": "execution",
        "selection_surface": "execution",
        "resource": "execution",
        "source_fields": ["execution_id", "scenario_name", "execution_status"]
      }
    },
    "triggerHints": {
      "scenario.trigger": {
        "event": {
          "default": "manual",
          "suggested_values": ["manual", "webhook", "scheduled", "replay", "custom"],
          "description": "Free-form label forwarded to the live Make bridge when triggering a scenario."
        },
        "payload": {
          "kind": "object",
          "input_mode": "key_value_pairs_or_json",
          "example": {
            "source": "agent",
            "reason": "follow-up"
          },
          "description": "Repeated --payload key=value entries become a JSON object; --payload-json can supply the object directly."
        },
        "response": {
          "acknowledged_from": ["status", "state", "result", "message"],
          "result_from": ["response", "result"]
        }
      },
      "execution.run": {
        "event": {
          "default": "manual",
          "suggested_values": ["manual", "webhook", "scheduled", "replay", "custom"],
          "description": "Free-form label forwarded to the live Make bridge when creating a scenario execution."
        },
        "payload": {
          "kind": "object",
          "input_mode": "key_value_pairs_or_json",
          "example": {
            "source": "agent",
            "reason": "follow-up"
          },
          "description": "Repeated --payload key=value entries become a JSON object; --payload-json can supply the object directly."
        },
        "response": {
          "acknowledged_from": ["status", "state", "result", "message"],
          "result_from": ["response", "result"]
        }
      }
    }
  },
  "connector": {
    "label": "Make",
    "category": "automation-orchestration",
    "categories": ["automation-orchestration", "workflow-automation", "integrations"],
    "resources": ["organization", "team", "scenario", "connection", "execution", "run"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["MAKE_API_URL", "MAKE_API_KEY"],
    "optional_service_keys": [
      "MAKE_WEBHOOK_BASE_URL",
      "MAKE_ORGANIZATION_ID",
      "MAKE_ORGANIZATION_NAME",
      "MAKE_TEAM_ID",
      "MAKE_TEAM_NAME",
      "MAKE_SCENARIO_ID",
      "MAKE_SCENARIO_NAME",
      "MAKE_SCENARIO_STATUS",
      "MAKE_CONNECTION_ID",
      "MAKE_CONNECTION_NAME",
      "MAKE_EXECUTION_ID",
      "MAKE_RUN_ID"
    ],
    "interactive_setup": [
      "Connect or proxy a live Make bridge for the workspace you want this worker to use.",
      "Add MAKE_API_URL and MAKE_API_KEY in operator-controlled service keys.",
      "Optionally set MAKE_WEBHOOK_BASE_URL if you need a stable public base for trigger execution callbacks.",
      "Optionally set MAKE_ORGANIZATION_NAME, MAKE_TEAM_NAME, MAKE_SCENARIO_NAME, and MAKE_CONNECTION_NAME in service keys to preview the selected scope.",
      "Use local MAKE_* environment variables only as harness fallbacks when operator keys are unavailable.",
      "Scoped service-key entries must be injected by the operator runtime and are not bypassed with local env.",
      "scenario.list, scenario.status, connection.list, and execution.list use the live Make read path.",
      "scenario.trigger and execution.run post a live execution payload through the configured bridge, but production live-write smoke is not claimed until tested against an operator Make bridge."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "organization.list",
      "summary": "List Make organizations from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "organization",
      "action_class": "read"
    },
    {
      "id": "team.list",
      "summary": "List Make teams from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "scenario.list",
      "summary": "List Make scenarios from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "scenario",
      "action_class": "read"
    },
    {
      "id": "scenario.status",
      "summary": "Read Make scenario status from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "scenario",
      "action_class": "read"
    },
    {
      "id": "connection.list",
      "summary": "List Make connections from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connection",
      "action_class": "read"
    },
    {
      "id": "execution.list",
      "summary": "List Make executions from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "execution",
      "action_class": "read"
    },
    {
      "id": "execution.status",
      "summary": "Read Make execution status from the live bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "execution",
      "action_class": "read"
    },
    {
      "id": "scenario.trigger",
      "summary": "Trigger a live Make scenario execution with builder hints",
      "required_mode": "write",
      "supports_json": true,
      "resource": "scenario",
      "action_class": "write",
      "input_hints": {
        "event": {
          "type": "string",
          "default": "manual",
          "suggested_values": ["manual", "webhook", "scheduled", "replay", "custom"],
          "description": "Free-form event label passed through to the live bridge."
        },
        "payload": {
          "type": "object",
          "shape": "flat key-value map",
          "description": "Repeated --payload key=value flags are merged into the JSON body as string fields.",
          "example": { "source": "agent", "reason": "follow-up" }
        }
      },
      "response_hints": {
        "type": "json",
        "normalized_fields": [
          "ok",
          "status_code",
          "response_kind",
          "execution_id",
          "response_status",
          "summary",
          "trigger_url_redacted"
        ],
        "description": "The bridge normalizes response metadata so UI code can show success state and execution IDs without parsing raw JSON."
      }
    },
    {
      "id": "execution.run",
      "summary": "Run a live Make scenario execution with builder hints",
      "required_mode": "write",
      "supports_json": true,
      "resource": "execution",
      "action_class": "write",
      "input_hints": {
        "event": {
          "type": "string",
          "default": "manual",
          "suggested_values": ["manual", "webhook", "scheduled", "replay", "custom"],
          "description": "Free-form event label passed through to the live bridge."
        },
        "payload": {
          "type": "object",
          "shape": "flat key-value map",
          "description": "Repeated --payload key=value flags are merged into the JSON body as string fields.",
          "example": { "source": "agent", "reason": "follow-up" }
        }
      },
      "response_hints": {
        "type": "json",
        "normalized_fields": [
          "ok",
          "status_code",
          "response_kind",
          "execution_id",
          "response_status",
          "summary",
          "trigger_url_redacted"
        ],
        "description": "The bridge normalizes response metadata so UI code can show success state and execution IDs without parsing raw JSON."
      }
    }
  ]
}
