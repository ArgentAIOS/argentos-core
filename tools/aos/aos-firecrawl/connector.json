{
  "tool": "aos-firecrawl",
  "backend": "firecrawl",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "knowledge-docs",
    "surface": "web-scrape-extract",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["url", "format", "limit", "include_html_tags", "wait_for_selector"],
    "worker_visible_actions": ["scrape"],
    "fields": [
      {
        "id": "url",
        "label": "URL",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["scrape"],
        "placeholder": "https://example.com/page",
        "description": "Public URL of the web page to scrape."
      },
      {
        "id": "format",
        "label": "Output Format",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["scrape"],
        "placeholder": "markdown",
        "description": "Format for the extracted content.",
        "options": [
          { "value": "markdown", "label": "Markdown" },
          { "value": "html", "label": "HTML" },
          { "value": "json", "label": "JSON" },
          { "value": "plaintext", "label": "Plain Text" }
        ],
        "default": "markdown"
      },
      {
        "id": "limit",
        "label": "Content Limit (Characters)",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["scrape"],
        "placeholder": "10000",
        "description": "Maximum characters to extract from the page."
      },
      {
        "id": "include_html_tags",
        "label": "Include HTML Tags",
        "type": "boolean",
        "renderAs": "boolean",
        "required": false,
        "expressionEnabled": false,
        "valueType": "boolean",
        "applies_to": ["scrape"],
        "default": false,
        "description": "Include HTML tags in the output (useful for markdown with formatting)."
      },
      {
        "id": "wait_for_selector",
        "label": "CSS Selector to Wait For",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["scrape"],
        "placeholder": ".dynamic-content",
        "description": "CSS selector for elements to wait for before scraping (for dynamic content)."
      }
    ],
    "commandDefaults": {
      "scrape": {
        "selection_surface": "page",
        "format": "markdown"
      }
    },
    "pickerHints": {
      "page": {
        "kind": "page",
        "selection_surface": "page",
        "resource": "firecrawl.page",
        "source_fields": ["url", "format", "content_length"]
      }
    }
  },
  "connector": {
    "label": "Firecrawl",
    "category": "knowledge-docs",
    "categories": ["knowledge-docs", "web-content", "research"],
    "resources": ["page", "scrape"]
  },
  "delivery_model": "poll",
  "risk_tier": "readonly-external",
  "auth": {
    "kind": "service-key",
    "required": false,
    "service_keys": ["FIRECRAWL_API_KEY"],
    "interactive_setup": [
      "Preferred: add FIRECRAWL_API_KEY in ArgentOS API Keys so the local dashboard proxy can resolve it.",
      "Optional: export FIRECRAWL_API_KEY directly in the gateway environment for direct API fallback.",
      "Keep this connector in readonly mode; it is intended for research and extraction, not mutation."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "List connector capabilities",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Check Firecrawl runtime readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run Firecrawl runtime diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted Firecrawl connector config",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "page",
      "action_class": "read"
    },
    {
      "id": "scrape",
      "summary": "Scrape readable content from a public URL",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "scrape",
      "action_class": "read"
    }
  ]
}
