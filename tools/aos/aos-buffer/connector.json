{
  "tool": "aos-buffer",
  "backend": "buffer-graphql-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "social-media",
    "surface": "account-organization-channel-post",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "live_write_smoke_tested": false,
    "required_one_of": [["BUFFER_API_KEY", "BUFFER_ACCESS_TOKEN"]],
    "optional": [
      "BUFFER_BASE_URL",
      "BUFFER_ORGANIZATION_ID",
      "BUFFER_CHANNEL_ID",
      "BUFFER_PROFILE_ID",
      "BUFFER_POST_ID"
    ],
    "workerFields": [
      "account",
      "organization_id",
      "channel_id",
      "profile_id",
      "post_id"
    ],
    "worker_visible_actions": [
      "account.read",
      "channel.list",
      "channel.read",
      "profile.list",
      "profile.read",
      "post.list",
      "post.read"
    ],
    "fields": [
      {
        "id": "account",
        "label": "Account",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["account.read"],
        "placeholder": "authenticated Buffer account",
        "description": "Refers to the authenticated Buffer account (read-only, populated on query)."
      },
      {
        "id": "organization_id",
        "label": "Organization ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["channel.list", "profile.list", "post.list", "post.read"],
        "placeholder": "org_123",
        "description": "Buffer organization ID used to scope channel and post discovery. Optional, but recommended when the account belongs to more than one organization."
      },
      {
        "id": "channel_id",
        "label": "Channel ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["channel.read", "post.list"],
        "placeholder": "chan_123",
        "description": "Buffer channel ID. Required to read one channel directly and used to scope post discovery."
      },
      {
        "id": "profile_id",
        "label": "Profile ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["profile.read", "post.list"],
        "placeholder": "chan_123",
        "description": "Legacy alias for a Buffer channel ID. Buffer's current GraphQL API calls these channels, but this field is retained for worker compatibility."
      },
      {
        "id": "post_id",
        "label": "Post ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["post.read"],
        "placeholder": "post_123",
        "description": "Buffer post ID used to search for a single post within the accessible organization scope."
      }
    ],
    "commandDefaults": {
      "account.read": {
        "selection_surface": "account"
      },
      "channel.list": {
        "selection_surface": "channel",
        "args": ["BUFFER_ORGANIZATION_ID"],
        "limit": 10
      },
      "channel.read": {
        "selection_surface": "channel",
        "args": ["BUFFER_CHANNEL_ID"]
      },
      "profile.list": {
        "selection_surface": "profile",
        "args": ["BUFFER_ORGANIZATION_ID"],
        "limit": 10
      },
      "profile.read": {
        "selection_surface": "profile",
        "args": ["BUFFER_PROFILE_ID"]
      },
      "post.list": {
        "selection_surface": "post",
        "args": ["BUFFER_ORGANIZATION_ID", "BUFFER_CHANNEL_ID"],
        "limit": 10
      },
      "post.read": {
        "selection_surface": "post",
        "args": ["BUFFER_POST_ID", "BUFFER_ORGANIZATION_ID"]
      }
    },
    "pickerHints": {
      "account": {
        "kind": "account",
        "selection_surface": "account",
        "resource": "buffer.account",
        "source_command": "account.read",
        "source_fields": ["id", "name", "email", "timezone", "organizations"]
      },
      "channel": {
        "kind": "channel",
        "selection_surface": "channel",
        "resource": "buffer.channel",
        "source_command": "channel.list",
        "source_fields": ["id", "name", "service", "organization_id", "isQueuePaused"]
      },
      "profile": {
        "kind": "profile",
        "selection_surface": "profile",
        "resource": "buffer.channel",
        "source_command": "profile.list",
        "source_fields": ["id", "name", "service", "organization_id", "isQueuePaused"]
      },
      "post": {
        "kind": "post",
        "selection_surface": "post",
        "resource": "buffer.post",
        "source_command": "post.list",
        "source_fields": ["id", "text", "status", "channelId", "dueAt", "organization_id"]
      }
    }
  },
  "connector": {
    "label": "Buffer",
    "category": "marketing-publishing",
    "categories": ["marketing-publishing", "social-media", "service-ops"],
    "resources": ["account", "channel", "profile", "post"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["BUFFER_API_KEY", "BUFFER_ACCESS_TOKEN"],
    "required_one_of": [["BUFFER_API_KEY", "BUFFER_ACCESS_TOKEN"]],
    "optional_service_keys": [
      "BUFFER_BASE_URL",
      "BUFFER_ORGANIZATION_ID",
      "BUFFER_CHANNEL_ID",
      "BUFFER_PROFILE_ID",
      "BUFFER_POST_ID"
    ],
    "interactive_setup": [
      "Create or choose a Buffer API key for the operator-controlled account.",
      "Add BUFFER_API_KEY or BUFFER_ACCESS_TOKEN in operator-controlled service keys before enabling live reads.",
      "Optional: set BUFFER_ORGANIZATION_ID, BUFFER_CHANNEL_ID, BUFFER_PROFILE_ID, and BUFFER_POST_ID in operator-controlled service keys to stabilize worker scope.",
      "Optional: set BUFFER_BASE_URL in operator-controlled service keys only if you need to point the harness at a non-default Buffer GraphQL host.",
      "Live reads use Buffer's GraphQL account, channel, and posts surfaces.",
      "Scoped service-key entries must be injected by the operator runtime and are not bypassed with local env.",
      "Keep live_write_smoke_tested=false unless a real operator Buffer tenant smoke test verifies writes.",
      "No draft or schedule write command is advertised until a live write bridge and approval policy are implemented."
    ]
  },
  "commands": [
    {
      "id": "account.read",
      "summary": "Read Buffer account metadata and organizations",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and Buffer GraphQL readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "channel.list",
      "summary": "List Buffer channels",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "channel",
      "action_class": "read"
    },
    {
      "id": "channel.read",
      "summary": "Read a Buffer channel",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "channel",
      "action_class": "read"
    },
    {
      "id": "profile.list",
      "summary": "List Buffer profile aliases backed by channels",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "profile",
      "action_class": "read"
    },
    {
      "id": "profile.read",
      "summary": "Read a Buffer profile alias backed by a channel",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "profile",
      "action_class": "read"
    },
    {
      "id": "post.list",
      "summary": "List Buffer posts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    },
    {
      "id": "post.read",
      "summary": "Read a Buffer post by scanning the accessible organization scope",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    }
  ]
}
