{
  "tool": "aos-buffer",
  "backend": "buffer-rest-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "social-media",
    "surface": "account-channel-profile-post-calendar-analytics",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": [
      "account",
      "profile_id",
      "text",
      "media_url",
      "scheduled_at",
      "channel_ids",
      "link"
    ],
    "worker_visible_actions": [
      "account.read",
      "channel.list",
      "profile.list",
      "post.list",
      "post.create",
      "calendar.list",
      "analytics.get"
    ],
    "fields": [
      {
        "id": "account",
        "label": "Account",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["account.read"],
        "placeholder": "connected Buffer account",
        "description": "Refers to the connected Buffer account (read-only, populated on query)."
      },
      {
        "id": "profile_id",
        "label": "Profile ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "profile.list",
          "post.list",
          "post.create",
          "post.update",
          "post.delete",
          "calendar.list",
          "analytics.get"
        ],
        "placeholder": "4eb854340acb04e870000010",
        "description": "Buffer social profile ID (Twitter, Facebook, LinkedIn, Instagram, etc.). Required for most post operations."
      },
      {
        "id": "text",
        "label": "Post text",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "rows": 4,
        "applies_to": ["post.create", "post.update"],
        "placeholder": "Draft launch announcement",
        "description": "The post content text. Supports platform-specific markdown and mentions."
      },
      {
        "id": "media_url",
        "label": "Media URL",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["post.create", "post.update"],
        "placeholder": "https://cdn.example.com/image.png",
        "description": "URL to image or video to attach to the post."
      },
      {
        "id": "scheduled_at",
        "label": "Scheduled at",
        "type": "text",
        "renderAs": "datetime",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["post.create", "post.update"],
        "placeholder": "2026-04-01T09:00:00Z",
        "description": "ISO 8601 timestamp for when to publish the post. Leave blank to publish immediately."
      },
      {
        "id": "channel_ids",
        "label": "Channel IDs",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["post.create", "post.update"],
        "placeholder": "chan_1,chan_2",
        "description": "Comma-separated list of Buffer channel IDs to post to. Can be a single channel or multiple."
      },
      {
        "id": "link",
        "label": "Link",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["post.create", "post.update"],
        "placeholder": "https://argentos.ai/blog/launch",
        "description": "URL to include in the post as a clickable link (for news feeds, etc.)."
      }
    ],
    "commandDefaults": {
      "account.read": {
        "selection_surface": "account"
      },
      "channel.list": {
        "selection_surface": "channel",
        "limit": 10
      },
      "profile.list": {
        "selection_surface": "profile",
        "limit": 10
      },
      "post.list": {
        "selection_surface": "post",
        "args": ["BUFFER_PROFILE_ID"],
        "limit": 10
      },
      "post.create": {
        "selection_surface": "post",
        "args": ["BUFFER_PROFILE_ID", "BUFFER_POST_TEXT"]
      },
      "post.update": {
        "selection_surface": "post",
        "args": ["BUFFER_POST_ID"]
      },
      "post.delete": {
        "selection_surface": "post",
        "args": ["BUFFER_POST_ID"]
      },
      "calendar.list": {
        "selection_surface": "calendar",
        "args": ["BUFFER_PROFILE_ID"],
        "limit": 30
      },
      "analytics.get": {
        "selection_surface": "analytics",
        "args": ["BUFFER_PROFILE_ID"]
      }
    },
    "pickerHints": {
      "account": {
        "kind": "account",
        "selection_surface": "account",
        "resource": "buffer.account",
        "source_command": "account.read",
        "source_fields": ["id", "name", "email", "timezone", "locale"]
      },
      "channel": {
        "kind": "channel",
        "selection_surface": "channel",
        "resource": "buffer.channel",
        "source_command": "channel.list",
        "source_fields": [
          "id",
          "service",
          "service_username",
          "formatted_username",
          "default",
          "timezone"
        ]
      },
      "profile": {
        "kind": "profile",
        "selection_surface": "profile",
        "resource": "buffer.profile",
        "source_command": "profile.list",
        "source_fields": [
          "id",
          "service",
          "service_username",
          "formatted_username",
          "default",
          "timezone"
        ]
      },
      "post": {
        "kind": "post",
        "selection_surface": "post",
        "resource": "buffer.post",
        "source_command": "post.list",
        "source_fields": [
          "id",
          "text",
          "status",
          "profile_id",
          "scheduled_at",
          "sent_at",
          "media_url",
          "link"
        ]
      },
      "calendar": {
        "kind": "calendar",
        "selection_surface": "calendar",
        "resource": "buffer.calendar",
        "source_command": "calendar.list",
        "source_fields": ["id", "day", "posts_count", "slots"]
      },
      "analytics": {
        "kind": "analytics",
        "selection_surface": "analytics",
        "resource": "buffer.analytics",
        "source_command": "analytics.get",
        "source_fields": ["profile_id", "impressions", "engagements", "clicks", "reach", "period"]
      }
    }
  },
  "connector": {
    "label": "Buffer",
    "category": "marketing-publishing",
    "categories": ["marketing-publishing", "social-media", "service-ops"],
    "resources": ["account", "channel", "profile", "post", "calendar", "analytics"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["BUFFER_API_KEY", "BUFFER_ACCESS_TOKEN"],
    "interactive_setup": [
      "Create or choose a Buffer API token for the workspace or account.",
      "Add BUFFER_API_KEY or BUFFER_ACCESS_TOKEN in API Keys before enabling live reads.",
      "Optional: set BUFFER_BASE_URL to pin a non-default Buffer REST host.",
      "The connector uses the current public /user and /profiles REST surfaces for account, channel, and profile reads.",
      "Keep post.create_draft and post.schedule scaffolded until the current Buffer post read/write contract is confirmed."
    ]
  },
  "commands": [
    {
      "id": "account.read",
      "summary": "Read Buffer account metadata",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and Buffer API readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "profile.list",
      "summary": "List Buffer profiles",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "profile",
      "action_class": "read"
    },
    {
      "id": "channel.list",
      "summary": "List Buffer channels",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "channel",
      "action_class": "read"
    },
    {
      "id": "post.create",
      "summary": "Create a Buffer post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "post.list",
      "summary": "List Buffer posts for a profile",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "post",
      "action_class": "read"
    },
    {
      "id": "post.update",
      "summary": "Update a Buffer post",
      "required_mode": "write",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "post.delete",
      "summary": "Delete a Buffer post",
      "required_mode": "full",
      "supports_json": true,
      "resource": "post",
      "action_class": "write"
    },
    {
      "id": "calendar.list",
      "summary": "List Buffer posting calendar slots",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "calendar",
      "action_class": "read"
    },
    {
      "id": "analytics.get",
      "summary": "Get Buffer analytics for a profile",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "analytics",
      "action_class": "read"
    }
  ]
}
