{
  "tool": "aos-n8n",
  "backend": "n8n-live-bridge",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "workflow-live-bridge",
    "surface": "workflow",
    "scaffold_only": false,
    "live_backend_available": true,
    "worker_visible_actions": ["workflow.list", "workflow.status", "workflow.trigger"],
    "workerFields": ["workflow_id", "workflow_name", "event", "payload"],
    "fields": [
      {
        "id": "workflow_id",
        "label": "Workflow ID",
        "type": "string",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "n8n workflow ID to target",
        "placeholder": "12345",
        "applies_to": ["workflow.status", "workflow.trigger"]
      },
      {
        "id": "workflow_name",
        "label": "Workflow Name",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional workflow name for display",
        "placeholder": "my-workflow",
        "applies_to": ["workflow.list", "workflow.trigger"]
      },
      {
        "id": "event",
        "label": "Event Type",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Type of event triggering the workflow",
        "options": [
          { "value": "manual", "label": "Manual Trigger" },
          { "value": "webhook", "label": "Webhook" },
          { "value": "schedule", "label": "Scheduled" },
          { "value": "replay", "label": "Replay" },
          { "value": "custom", "label": "Custom" }
        ],
        "default": "manual",
        "applies_to": ["workflow.trigger"]
      },
      {
        "id": "payload",
        "label": "Trigger Payload",
        "type": "json",
        "renderAs": "json",
        "required": false,
        "expressionEnabled": true,
        "valueType": "json",
        "description": "JSON payload data to pass to the workflow",
        "placeholder": "{\"source\": \"agent\", \"reason\": \"follow-up\"}",
        "applies_to": ["workflow.trigger"]
      }
    ]
  },
  "connector": {
    "label": "n8n",
    "category": "automation-orchestration",
    "categories": ["automation-orchestration", "workflow-automation", "integrations"],
    "resources": ["workflow", "execution", "trigger"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["N8N_API_URL", "N8N_API_KEY", "N8N_WEBHOOK_BASE_URL"],
    "interactive_setup": [
      "Create or connect an n8n instance for the workspace you want this worker to use.",
      "Add N8N_API_URL, N8N_API_KEY, and N8N_WEBHOOK_BASE_URL in operator-controlled API Keys.",
      "Use local N8N_API_URL, N8N_API_KEY, and N8N_WEBHOOK_BASE_URL environment variables only as harness fallbacks when operator keys are unavailable.",
      "workflow.list and workflow.status use the live n8n API read path.",
      "workflow.trigger posts a live webhook execution payload through the bridge."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "workflow.list",
      "summary": "List workflows from the live n8n API",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "workflow",
      "action_class": "read"
    },
    {
      "id": "workflow.status",
      "summary": "Read live workflow status from the n8n API",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "workflow",
      "action_class": "read"
    },
    {
      "id": "workflow.trigger",
      "summary": "Trigger a live n8n workflow execution bridge with builder hints",
      "required_mode": "write",
      "supports_json": true,
      "resource": "workflow",
      "action_class": "write",
      "input_hints": {
        "event": {
          "type": "string",
          "default": "manual",
          "suggested_values": ["manual", "webhook", "schedule", "replay", "custom"],
          "description": "Free-form event label passed through to the webhook body."
        },
        "payload": {
          "type": "object",
          "shape": "flat key-value map",
          "description": "Repeated --payload key=value flags are merged into the JSON body as string fields.",
          "example": { "source": "agent", "reason": "follow-up" }
        }
      },
      "response_hints": {
        "type": "json",
        "normalized_fields": [
          "ok",
          "status_code",
          "response_kind",
          "execution_id",
          "response_status",
          "summary",
          "trigger_url_redacted"
        ],
        "description": "The bridge normalizes response metadata so UI code can show success state and execution IDs without parsing raw JSON."
      }
    }
  ]
}
