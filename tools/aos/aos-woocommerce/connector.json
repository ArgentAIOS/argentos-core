{
  "tool": "aos-woocommerce",
  "backend": "woocommerce-rest-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "commerce",
    "surface": "order-product-customer-coupon-report",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["store_url", "order_id", "product_id", "customer_id", "status", "sku"],
    "worker_visible_actions": [
      "order.list",
      "order.get",
      "product.list",
      "product.get",
      "customer.list",
      "customer.get",
      "coupon.list",
      "report.sales",
      "report.top_sellers"
    ],
    "fields": [
      {
        "id": "store_url",
        "label": "Store URL",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "order.list",
          "order.get",
          "order.create",
          "order.update",
          "product.list",
          "product.get",
          "product.create",
          "product.update",
          "customer.list",
          "customer.get",
          "customer.create",
          "coupon.list",
          "coupon.create",
          "report.sales",
          "report.top_sellers"
        ],
        "example": "https://mystore.example.com",
        "placeholder": "https://mystore.example.com",
        "description": "Your WooCommerce store base URL."
      },
      {
        "id": "order_id",
        "label": "Order ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["order.get", "order.update"],
        "example": "1234",
        "placeholder": "e.g., 1234",
        "description": "The WooCommerce order ID."
      },
      {
        "id": "product_id",
        "label": "Product ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["product.get", "product.update"],
        "example": "567",
        "placeholder": "e.g., 567",
        "description": "The WooCommerce product ID."
      },
      {
        "id": "customer_id",
        "label": "Customer ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["customer.get", "order.list"],
        "example": "89",
        "placeholder": "e.g., 89",
        "description": "The WooCommerce customer ID."
      },
      {
        "id": "status",
        "label": "Status filter",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["order.list", "order.update", "product.list", "product.update"],
        "example": "processing, completed, pending, publish, draft",
        "options": [
          { "value": "processing", "label": "Processing" },
          { "value": "completed", "label": "Completed" },
          { "value": "pending", "label": "Pending" },
          { "value": "publish", "label": "Published" },
          { "value": "draft", "label": "Draft" }
        ],
        "placeholder": "Select status...",
        "description": "Filter orders or products by status."
      },
      {
        "id": "sku",
        "label": "Product SKU",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["product.list", "product.get"],
        "example": "WOO-WIDGET-001",
        "placeholder": "e.g., WOO-WIDGET-001",
        "description": "Product Stock Keeping Unit (SKU) for inventory tracking."
      }
    ],
    "commandDefaults": {
      "order.list": {
        "selection_surface": "order",
        "limit": 10,
        "status_env": "WOO_ORDER_STATUS"
      },
      "order.get": {
        "selection_surface": "order",
        "args": ["WOO_ORDER_ID"]
      },
      "order.create": {
        "selection_surface": "order"
      },
      "order.update": {
        "selection_surface": "order",
        "args": ["WOO_ORDER_ID"]
      },
      "product.list": {
        "selection_surface": "product",
        "limit": 10,
        "status_env": "WOO_PRODUCT_STATUS"
      },
      "product.get": {
        "selection_surface": "product",
        "args": ["WOO_PRODUCT_ID"]
      },
      "product.create": {
        "selection_surface": "product"
      },
      "product.update": {
        "selection_surface": "product",
        "args": ["WOO_PRODUCT_ID"]
      },
      "customer.list": {
        "selection_surface": "customer",
        "limit": 10
      },
      "customer.get": {
        "selection_surface": "customer",
        "args": ["WOO_CUSTOMER_ID"]
      },
      "customer.create": {
        "selection_surface": "customer"
      },
      "coupon.list": {
        "selection_surface": "coupon",
        "limit": 10
      },
      "coupon.create": {
        "selection_surface": "coupon"
      },
      "report.sales": {
        "selection_surface": "report"
      },
      "report.top_sellers": {
        "selection_surface": "report"
      }
    },
    "pickerHints": {
      "order": {
        "kind": "order",
        "selection_surface": "order",
        "resource": "woocommerce.order",
        "source_command": "order.list",
        "source_fields": ["id", "number", "status", "total", "currency", "date_created", "billing"]
      },
      "product": {
        "kind": "product",
        "selection_surface": "product",
        "resource": "woocommerce.product",
        "source_command": "product.list",
        "source_fields": ["id", "name", "sku", "status", "price", "stock_status", "type"]
      },
      "customer": {
        "kind": "customer",
        "selection_surface": "customer",
        "resource": "woocommerce.customer",
        "source_command": "customer.list",
        "source_fields": ["id", "email", "first_name", "last_name", "date_created", "orders_count"]
      },
      "coupon": {
        "kind": "coupon",
        "selection_surface": "coupon",
        "resource": "woocommerce.coupon",
        "source_command": "coupon.list",
        "source_fields": ["id", "code", "discount_type", "amount", "usage_count", "date_expires"]
      },
      "report": {
        "kind": "report",
        "selection_surface": "report",
        "resource": "woocommerce.report",
        "source_command": "report.sales",
        "source_fields": [
          "total_sales",
          "net_sales",
          "total_orders",
          "total_items",
          "total_customers"
        ]
      }
    }
  },
  "connector": {
    "label": "WooCommerce",
    "category": "commerce-ops",
    "categories": ["commerce-ops", "orders", "inventory", "crm-revenue"],
    "resources": ["order", "product", "customer", "coupon", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["WOO_STORE_URL", "WOO_CONSUMER_KEY", "WOO_CONSUMER_SECRET"],
    "interactive_setup": [
      "Generate WooCommerce REST API keys under WooCommerce > Settings > Advanced > REST API.",
      "Preferred: add WOO_STORE_URL, WOO_CONSUMER_KEY, and WOO_CONSUMER_SECRET in operator-controlled API Keys; the harness falls back to local process env only for development.",
      "The connector targets WooCommerce REST API v3 at {store_url}/wp-json/wc/v3.",
      "Only live read commands are enabled today; all write commands remain scaffold placeholders until WooCommerce write workflows are approved.",
      "The connector is live-read-first and will report API failures instead of masking them."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and WooCommerce API readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "order.list",
      "summary": "List WooCommerce orders",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "order.get",
      "summary": "Get a WooCommerce order",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "order",
      "action_class": "read"
    },
    {
      "id": "order.create",
      "summary": "Scaffold placeholder for creating a WooCommerce order",
      "required_mode": "write",
      "supports_json": true,
      "resource": "order",
      "action_class": "write"
    },
    {
      "id": "order.update",
      "summary": "Scaffold placeholder for updating a WooCommerce order",
      "required_mode": "write",
      "supports_json": true,
      "resource": "order",
      "action_class": "write"
    },
    {
      "id": "product.list",
      "summary": "List WooCommerce products",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "product",
      "action_class": "read"
    },
    {
      "id": "product.get",
      "summary": "Get a WooCommerce product",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "product",
      "action_class": "read"
    },
    {
      "id": "product.create",
      "summary": "Scaffold placeholder for creating a WooCommerce product",
      "required_mode": "write",
      "supports_json": true,
      "resource": "product",
      "action_class": "write"
    },
    {
      "id": "product.update",
      "summary": "Scaffold placeholder for updating a WooCommerce product",
      "required_mode": "write",
      "supports_json": true,
      "resource": "product",
      "action_class": "write"
    },
    {
      "id": "customer.list",
      "summary": "List WooCommerce customers",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.get",
      "summary": "Get a WooCommerce customer",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.create",
      "summary": "Scaffold placeholder for creating a WooCommerce customer",
      "required_mode": "write",
      "supports_json": true,
      "resource": "customer",
      "action_class": "write"
    },
    {
      "id": "coupon.list",
      "summary": "List WooCommerce coupons",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "coupon",
      "action_class": "read"
    },
    {
      "id": "coupon.create",
      "summary": "Scaffold placeholder for creating a WooCommerce coupon",
      "required_mode": "write",
      "supports_json": true,
      "resource": "coupon",
      "action_class": "write"
    },
    {
      "id": "report.sales",
      "summary": "Get WooCommerce sales report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.top_sellers",
      "summary": "Get WooCommerce top sellers report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    }
  ]
}
