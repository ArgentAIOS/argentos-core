{
  "tool": "aos-xero",
  "backend": "xero-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "accounting",
    "surface": "invoice-contact-payment-account-bank-transaction-report-quote",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": [
      "tenant_id",
      "contact_id",
      "invoice_id",
      "payment_id",
      "date"
    ],
    "worker_visible_actions": [
      "invoice.list",
      "invoice.get",
      "contact.list",
      "contact.get",
      "payment.list",
      "payment.get",
      "account.list",
      "bank_transaction.list",
      "report.profit_loss",
      "report.balance_sheet",
      "quote.list"
    ],
    "fields": [
      {
        "id": "tenant_id",
        "label": "Tenant ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "invoice.list",
          "invoice.get",
          "contact.list",
          "contact.get",
          "payment.list",
          "payment.get",
          "account.list",
          "bank_transaction.list",
          "report.profit_loss",
          "report.balance_sheet",
          "quote.list"
        ],
        "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "placeholder": "e.g., a1b2c3d4-e5f6-7890-abcd-ef1234567890",
        "description": "The Xero tenant (organisation) UUID."
      },
      {
        "id": "contact_id",
        "label": "Contact ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "contact.get"
        ],
        "example": "c1d2e3f4-a5b6-7890-cdef-ab1234567890",
        "placeholder": "Select contact...",
        "description": "The Xero contact (customer/supplier) ID."
      },
      {
        "id": "invoice_id",
        "label": "Invoice ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "invoice.get"
        ],
        "example": "i1j2k3l4-m5n6-7890-opqr-st1234567890",
        "placeholder": "Select invoice...",
        "description": "The Xero invoice ID."
      },
      {
        "id": "payment_id",
        "label": "Payment ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "payment.get"
        ],
        "example": "p1q2r3s4-t5u6-7890-vwxy-z1234567890",
        "placeholder": "Select payment...",
        "description": "The Xero payment ID."
      },
      {
        "id": "date",
        "label": "Date",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": [
          "report.profit_loss",
          "report.balance_sheet"
        ],
        "example": "2026-03-26",
        "placeholder": "YYYY-MM-DD",
        "description": "Transaction date in ISO 8601 format."
      }
    ],
    "commandDefaults": {
      "invoice.list": {
        "selection_surface": "invoice",
        "limit": 25,
        "statuses": [
          "AUTHORISED",
          "SUBMITTED"
        ]
      },
      "invoice.get": {
        "selection_surface": "invoice",
        "args": [
          "XERO_INVOICE_ID"
        ]
      },
      "contact.list": {
        "selection_surface": "contact",
        "limit": 25
      },
      "contact.get": {
        "selection_surface": "contact",
        "args": [
          "XERO_CONTACT_ID"
        ]
      },
      "payment.list": {
        "selection_surface": "payment",
        "limit": 25
      },
      "payment.get": {
        "selection_surface": "payment",
        "args": [
          "XERO_PAYMENT_ID"
        ]
      },
      "account.list": {
        "selection_surface": "account",
        "limit": 100
      },
      "bank_transaction.list": {
        "selection_surface": "bank_transaction",
        "limit": 25
      },
      "report.profit_loss": {
        "selection_surface": "report",
        "args": [
          "XERO_DATE"
        ]
      },
      "report.balance_sheet": {
        "selection_surface": "report",
        "args": [
          "XERO_DATE"
        ]
      },
      "quote.list": {
        "selection_surface": "quote",
        "limit": 25
      }
    },
    "pickerHints": {
      "invoice": {
        "kind": "invoice",
        "selection_surface": "invoice",
        "resource": "xero.invoice",
        "source_command": "invoice.list",
        "source_fields": [
          "id",
          "number",
          "contact",
          "status",
          "total",
          "amount_due",
          "currency",
          "date",
          "due_date"
        ]
      },
      "contact": {
        "kind": "contact",
        "selection_surface": "contact",
        "resource": "xero.contact",
        "source_command": "contact.list",
        "source_fields": [
          "id",
          "name",
          "email",
          "phone",
          "is_customer",
          "is_supplier",
          "outstanding_balance"
        ]
      },
      "payment": {
        "kind": "payment",
        "selection_surface": "payment",
        "resource": "xero.payment",
        "source_command": "payment.list",
        "source_fields": [
          "id",
          "invoice",
          "amount",
          "currency",
          "date",
          "status",
          "payment_type"
        ]
      },
      "account": {
        "kind": "account",
        "selection_surface": "account",
        "resource": "xero.account",
        "source_command": "account.list",
        "source_fields": [
          "code",
          "name",
          "type",
          "class",
          "status",
          "tax_type",
          "description"
        ]
      },
      "bank_transaction": {
        "kind": "bank_transaction",
        "selection_surface": "bank_transaction",
        "resource": "xero.bank_transaction",
        "source_command": "bank_transaction.list",
        "source_fields": [
          "id",
          "type",
          "contact",
          "total",
          "date",
          "status",
          "bank_account"
        ]
      },
      "quote": {
        "kind": "quote",
        "selection_surface": "quote",
        "resource": "xero.quote",
        "source_command": "quote.list",
        "source_fields": [
          "id",
          "number",
          "contact",
          "status",
          "total",
          "date",
          "expiry_date"
        ]
      }
    }
  },
  "connector": {
    "label": "Xero",
    "category": "finance-accounting",
    "categories": [
      "finance-accounting",
      "accounting",
      "invoicing",
      "reporting"
    ],
    "resources": [
      "invoice",
      "contact",
      "payment",
      "account",
      "bank_transaction",
      "report",
      "quote"
    ]
  },
  "auth": {
    "kind": "oauth2",
    "required": true,
    "service_keys": [
      "XERO_CLIENT_ID",
      "XERO_CLIENT_SECRET",
      "XERO_REFRESH_TOKEN",
      "XERO_TENANT_ID",
      "XERO_CONTACT_ID",
      "XERO_INVOICE_ID",
      "XERO_PAYMENT_ID",
      "XERO_DATE",
      "XERO_API_BASE_URL",
      "XERO_TOKEN_URL"
    ],
    "interactive_setup": [
      "Create a Xero OAuth app and configure Accounting API scopes for read-only access.",
      "Add XERO_CLIENT_ID, XERO_CLIENT_SECRET, XERO_REFRESH_TOKEN, and XERO_TENANT_ID in operator-controlled API Keys before enabling live reads.",
      "Optional linking keys such as XERO_CONTACT_ID, XERO_INVOICE_ID, XERO_PAYMENT_ID, and XERO_DATE are also resolved from operator-controlled API Keys first.",
      "No Xero write command is advertised until live write workflows and approval policy are implemented.",
      "The connector is live-read-first and will report API failures instead of masking them."
    ]
  },
  "commands": [
    {
      "id": "invoice.list",
      "summary": "List Xero invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "invoice.get",
      "summary": "Get a Xero invoice by ID",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "contact.list",
      "summary": "List Xero contacts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "contact",
      "action_class": "read"
    },
    {
      "id": "contact.get",
      "summary": "Get a Xero contact by ID",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "contact",
      "action_class": "read"
    },
    {
      "id": "payment.list",
      "summary": "List Xero payments",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "payment.get",
      "summary": "Get a Xero payment by ID",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "account.list",
      "summary": "List Xero chart of accounts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "bank_transaction.list",
      "summary": "List Xero bank transactions",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "bank_transaction",
      "action_class": "read"
    },
    {
      "id": "report.profit_loss",
      "summary": "Generate a Xero Profit & Loss report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.balance_sheet",
      "summary": "Generate a Xero Balance Sheet report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "quote.list",
      "summary": "List Xero quotes",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "quote",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
