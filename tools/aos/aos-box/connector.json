{
  "tool": "aos-box",
  "backend": "box-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "document-storage",
    "surface": "file-folder-collaboration",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["file_id", "folder_id", "query"],
    "worker_visible_actions": [
      "file.list",
      "file.get",
      "file.download",
      "folder.list",
      "folder.get",
      "collaboration.list",
      "metadata.get",
      "search.query"
    ],
    "fields": [
      {
        "id": "file_id",
        "label": "File ID",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Box file ID for file-level operations",
        "placeholder": "123456789",
        "applies_to": [
          "file.get",
          "file.download",
          "metadata.get"
        ],
        "example": "123456789"
      },
      {
        "id": "folder_id",
        "label": "Folder ID",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Box folder ID for listing items and reading folder metadata",
        "placeholder": "987654321",
        "applies_to": [
          "file.list",
          "folder.list",
          "folder.get",
          "collaboration.list"
        ],
        "example": "987654321"
      },
      {
        "id": "query",
        "label": "Search query",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Box search query string",
        "placeholder": "annual report 2026",
        "applies_to": ["search.query"],
        "example": "annual report 2026"
      }
    ],
    "commandDefaults": {
      "file.list": {
        "selection_surface": "file",
        "args": ["BOX_FOLDER_ID"],
        "limit": 25
      },
      "file.get": {
        "selection_surface": "file",
        "args": ["BOX_FILE_ID"]
      },
      "file.download": {
        "selection_surface": "file",
        "args": ["BOX_FILE_ID"]
      },
      "folder.list": {
        "selection_surface": "folder",
        "args": ["BOX_FOLDER_ID"],
        "limit": 25
      },
      "folder.get": {
        "selection_surface": "folder",
        "args": ["BOX_FOLDER_ID"]
      },
      "collaboration.list": {
        "selection_surface": "collaboration",
        "args": ["BOX_FOLDER_ID"]
      },
      "search.query": {
        "selection_surface": "file",
        "query": "BOX_QUERY",
        "limit": 25
      },
      "metadata.get": {
        "selection_surface": "file",
        "args": ["BOX_FILE_ID"]
      }
    },
    "pickerHints": {
      "file": {
        "kind": "file",
        "selection_surface": "file",
        "resource": "box.file",
        "source_command": "file.list",
        "source_fields": [
          "id",
          "name",
          "size",
          "modified_at",
          "created_at",
          "owned_by",
          "shared_link"
        ]
      },
      "folder": {
        "kind": "folder",
        "selection_surface": "folder",
        "resource": "box.folder",
        "source_command": "folder.list",
        "source_fields": ["id", "name", "modified_at", "created_at", "owned_by", "item_collection"]
      },
      "collaboration": {
        "kind": "collaboration",
        "selection_surface": "collaboration",
        "resource": "box.collaboration",
        "source_command": "collaboration.list",
        "source_fields": ["id", "type", "role", "accessible_by", "status", "created_at"]
      }
    }
  },
  "connector": {
    "label": "Box",
    "category": "document-storage",
    "categories": ["document-storage", "productivity", "collaboration", "enterprise"],
    "resources": ["file", "folder", "collaboration"]
  },
  "auth": {
    "kind": "oauth2",
    "required": true,
    "service_keys": [
      "BOX_ACCESS_TOKEN",
      "BOX_CLIENT_ID",
      "BOX_CLIENT_SECRET",
      "BOX_JWT_CONFIG",
      "BOX_FOLDER_ID",
      "BOX_FILE_ID",
      "BOX_QUERY"
    ],
    "interactive_setup": [
      "Create a Box application at https://app.box.com/developers/console.",
      "Choose 'Custom App' with 'User Authentication (OAuth 2.0)' or 'Server Authentication (JWT)'.",
      "Add BOX_CLIENT_ID, BOX_CLIENT_SECRET, and BOX_ACCESS_TOKEN in API Keys.",
      "For JWT auth, alternatively provide BOX_JWT_CONFIG with the full JSON config from Box.",
      "Required scopes: Read all files and folders, read collaborations, and read metadata.",
      "Set BOX_FOLDER_ID to scope default listings to a specific folder (optional, default '0' for root).",
      "Set BOX_FILE_ID and BOX_QUERY for worker flow defaults.",
      "The connector is live read-only and will report API failures instead of masking them.",
      "Box write operations are not advertised until a write bridge and approval policy are verified."
    ]
  },
  "commands": [
    {
      "id": "file.list",
      "summary": "List files in a Box folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.get",
      "summary": "Get metadata for a Box file",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.download",
      "summary": "Download a file from Box",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "folder.list",
      "summary": "List items in a Box folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "folder",
      "action_class": "read"
    },
    {
      "id": "folder.get",
      "summary": "Get metadata for a Box folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "folder",
      "action_class": "read"
    },
    {
      "id": "collaboration.list",
      "summary": "List collaborations on a Box folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "collaboration",
      "action_class": "read"
    },
    {
      "id": "search.query",
      "summary": "Search for files and folders in Box",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "metadata.get",
      "summary": "Get metadata on a Box file",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
