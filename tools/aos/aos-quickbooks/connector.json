{
  "tool": "aos-quickbooks",
  "backend": "quickbooks-online",
  "manifest_schema_version": "1.0.0",
  "connector": {
    "label": "QuickBooks Online",
    "category": "finance-backoffice",
    "categories": ["finance-backoffice", "bookkeeping", "accounting"],
    "resources": [
      "company",
      "customer",
      "vendor",
      "invoice",
      "bill",
      "payment",
      "account",
      "transaction"
    ]
  },
  "scope": {
    "kind": "accounting",
    "surface": "invoice-customer-vendor-payment-account",
    "fields": [
      {
        "id": "customer_id",
        "label": "Customer ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["customer.read", "invoice.create_draft"],
        "placeholder": "Select customer...",
        "description": "The QuickBooks customer ID for invoicing."
      },
      {
        "id": "vendor_id",
        "label": "Vendor ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["vendor.read", "bill.create_draft"],
        "placeholder": "Select vendor...",
        "description": "The QuickBooks vendor ID for bill creation."
      },
      {
        "id": "invoice_id",
        "label": "Invoice ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["invoice.read"],
        "placeholder": "e.g., 123",
        "description": "The QuickBooks invoice ID to retrieve."
      },
      {
        "id": "bill_id",
        "label": "Bill ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["bill.read"],
        "placeholder": "e.g., 456",
        "description": "The QuickBooks bill ID to retrieve."
      },
      {
        "id": "amount",
        "label": "Amount",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["invoice.create_draft", "bill.create_draft", "payment.create_draft"],
        "placeholder": "e.g., 1500.00",
        "description": "Transaction amount in the default currency."
      },
      {
        "id": "account_id",
        "label": "Account ID",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["account.read"],
        "placeholder": "Select account...",
        "description": "The QuickBooks account (chart of accounts) ID."
      },
      {
        "id": "description",
        "label": "Description",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["invoice.create_draft", "bill.create_draft"],
        "placeholder": "Describe the transaction...",
        "description": "Description or memo for the invoice or bill."
      },
      {
        "id": "due_date",
        "label": "Due Date",
        "type": "text",
        "renderAs": "datetime",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["invoice.create_draft", "bill.create_draft"],
        "placeholder": "YYYY-MM-DD",
        "description": "Due date for the invoice or bill in ISO 8601 format."
      },
      {
        "id": "due_before",
        "label": "Due Before",
        "type": "text",
        "renderAs": "datetime",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["invoice.list_overdue"],
        "placeholder": "YYYY-MM-DD",
        "description": "Upper due-date bound for overdue open invoice reads. Defaults to today."
      },
      {
        "id": "query",
        "label": "Search Query",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["customer.search", "vendor.search", "invoice.search", "bill.search"],
        "placeholder": "e.g., Acme Corp",
        "description": "Search query for finding customers, vendors, or transactions."
      }
    ],
    "pickerHints": {
      "customer": {
        "kind": "customer",
        "resource": "quickbooks.customer",
        "source_command": "customer.list",
        "source_fields": ["id", "displayName", "email", "primaryPhone"]
      },
      "vendor": {
        "kind": "vendor",
        "resource": "quickbooks.vendor",
        "source_command": "vendor.list",
        "source_fields": ["id", "displayName", "email", "primaryPhone"]
      },
      "account": {
        "kind": "account",
        "resource": "quickbooks.account",
        "source_command": "account.list",
        "source_fields": ["id", "name", "type", "currentBalance"]
      }
    }
  },
  "auth": {
    "kind": "oauth-service-key",
    "required": true,
    "service_keys": ["QBO_CLIENT_ID", "QBO_CLIENT_SECRET", "QBO_REFRESH_TOKEN", "QBO_REALM_ID"],
    "interactive_setup": [
      "Create an Intuit developer app for QuickBooks Online.",
      "Add QBO_CLIENT_ID, QBO_CLIENT_SECRET, QBO_REFRESH_TOKEN, and QBO_REALM_ID in API Keys.",
      "Keep company, account, and date-window scope narrow before enabling write actions."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and backend readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "company.read",
      "summary": "Read QuickBooks company info",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "company",
      "action_class": "read"
    },
    {
      "id": "customer.list",
      "summary": "List customers",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.search",
      "summary": "Search customers",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "customer.read",
      "summary": "Read a customer",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "customer",
      "action_class": "read"
    },
    {
      "id": "vendor.list",
      "summary": "List vendors",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "vendor",
      "action_class": "read"
    },
    {
      "id": "vendor.search",
      "summary": "Search vendors",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "vendor",
      "action_class": "read"
    },
    {
      "id": "vendor.read",
      "summary": "Read a vendor",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "vendor",
      "action_class": "read"
    },
    {
      "id": "invoice.list",
      "summary": "List invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "invoice.list_overdue",
      "summary": "List overdue open invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "invoice.search",
      "summary": "Search invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "invoice.read",
      "summary": "Read an invoice",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "read"
    },
    {
      "id": "invoice.create_draft",
      "summary": "Create a draft invoice",
      "required_mode": "write",
      "supports_json": true,
      "resource": "invoice",
      "action_class": "write"
    },
    {
      "id": "bill.list",
      "summary": "List bills",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "bill",
      "action_class": "read"
    },
    {
      "id": "bill.search",
      "summary": "Search bills",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "bill",
      "action_class": "read"
    },
    {
      "id": "bill.read",
      "summary": "Read a bill",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "bill",
      "action_class": "read"
    },
    {
      "id": "bill.create_draft",
      "summary": "Create a draft bill",
      "required_mode": "write",
      "supports_json": true,
      "resource": "bill",
      "action_class": "write"
    },
    {
      "id": "payment.list",
      "summary": "List payments",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "payment.read",
      "summary": "Read a payment",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "payment",
      "action_class": "read"
    },
    {
      "id": "account.list",
      "summary": "List chart of accounts entries",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "account.read",
      "summary": "Read an account",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "transaction.list",
      "summary": "List transactions",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transaction",
      "action_class": "read"
    },
    {
      "id": "transaction.read",
      "summary": "Read a transaction",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transaction",
      "action_class": "read"
    }
  ]
}
