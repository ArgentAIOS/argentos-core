{
  "tool": "aos-zapier",
  "backend": "zapier-bridge",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "zapier-bridge",
    "surface": "zap",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "live_write_available": true,
    "write_bridge_available": true,
    "live_write_smoke_tested": false,
    "required": ["ZAPIER_API_URL", "ZAPIER_API_KEY"],
    "optional": [
      "ZAPIER_WEBHOOK_BASE_URL",
      "ZAPIER_WORKSPACE_NAME",
      "ZAPIER_ZAP_ID",
      "ZAPIER_ZAP_NAME",
      "ZAPIER_ZAP_STATUS"
    ],
    "workerFields": ["zap_id", "zap_name", "event", "payload", "enabled"],
    "worker_visible_actions": ["zap.list", "zap.status", "zap.trigger"],
    "fields": [
      {
        "id": "zap_id",
        "label": "Zap ID",
        "type": "string",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Zapier Zap ID to target",
        "placeholder": "98765",
        "applies_to": ["zap.status", "zap.trigger"]
      },
      {
        "id": "zap_name",
        "label": "Zap Name",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Zap name for display",
        "placeholder": "my-zap",
        "applies_to": ["zap.list", "zap.trigger"]
      },
      {
        "id": "event",
        "label": "Event Type",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Type of event triggering the Zap",
        "options": [
          { "value": "manual", "label": "Manual Trigger" },
          { "value": "scheduled", "label": "Scheduled" },
          { "value": "webhook", "label": "Webhook" },
          { "value": "test", "label": "Test" }
        ],
        "default": "manual",
        "applies_to": ["zap.trigger"]
      },
      {
        "id": "payload",
        "label": "Trigger Payload",
        "type": "json",
        "renderAs": "json",
        "required": false,
        "expressionEnabled": true,
        "valueType": "json",
        "description": "JSON payload data to pass to the Zap",
        "placeholder": "{\"source\": \"agent\", \"reason\": \"manual\"}",
        "applies_to": ["zap.trigger"]
      },
      {
        "id": "enabled",
        "label": "Zap Enabled",
        "type": "boolean",
        "renderAs": "boolean",
        "required": false,
        "expressionEnabled": false,
        "valueType": "boolean",
        "description": "Whether the Zap is enabled",
        "default": true,
        "applies_to": ["zap.status"]
      }
    ],
    "commandDefaults": {
      "zap.list": {
        "selection_surface": "zap",
        "limit": 10
      },
      "zap.status": {
        "selection_surface": "zap"
      },
      "zap.trigger": {
        "selection_surface": "zap",
        "event": "manual",
        "payload_mode": "key_value_pairs_or_json",
        "event_hints": ["manual", "scheduled", "webhook", "test"],
        "payload_example": {
          "source": "agent",
          "reason": "manual"
        }
      }
    },
    "triggerHints": {
      "zap.trigger": {
        "event": {
          "default": "manual",
          "suggested_values": ["manual", "scheduled", "webhook", "test"],
          "description": "Trigger label forwarded to the configured Zapier bridge."
        },
        "payload": {
          "kind": "object",
          "input_mode": "key_value_pairs_or_json",
          "example": {
            "source": "agent",
            "reason": "manual"
          },
          "description": "Repeated --payload key=value entries become a JSON object; --payload-json can supply the object directly."
        },
        "response": {
          "acknowledged_from": ["status", "state", "result", "message"],
          "result_from": ["response", "result"]
        }
      }
    },
    "pickerHints": {
      "workspace": {
        "kind": "workspace",
        "selection_surface": "workspace",
        "items": [
          {
            "value": "current",
            "label": "Current Zapier workspace",
            "resource": "zap.workspace"
          }
        ]
      },
      "zap": {
        "kind": "zap",
        "selection_surface": "zap",
        "resource": "zap.zap",
        "source_fields": ["zap_id", "zap_name", "zap_status"]
      }
    }
  },
  "connector": {
    "label": "Zapier",
    "category": "automation-orchestration",
    "categories": ["automation-orchestration", "workflow-automation", "integrations"],
    "resources": ["zap", "trigger", "workspace"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["ZAPIER_API_URL", "ZAPIER_API_KEY"],
    "interactive_setup": [
      "Add ZAPIER_API_URL and ZAPIER_API_KEY in operator-controlled API Keys to point at the live Zapier bridge.",
      "Optionally add ZAPIER_WEBHOOK_BASE_URL, ZAPIER_WORKSPACE_NAME, ZAPIER_ZAP_ID, ZAPIER_ZAP_NAME, and ZAPIER_ZAP_STATUS in API Keys to pin builder defaults.",
      "Use local env only as a harness fallback when operator-controlled API Keys are unavailable.",
      "zap.trigger uses the configured bridge when POST /trigger is available, but production live-write smoke is not claimed until tested against an operator Zapier bridge."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "zap.list",
      "summary": "List Zapier zaps through the configured bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "zap",
      "action_class": "read"
    },
    {
      "id": "zap.status",
      "summary": "Read Zapier zap status through the configured bridge",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "zap",
      "action_class": "read"
    },
    {
      "id": "zap.trigger",
      "summary": "Trigger a Zapier zap through the configured bridge",
      "required_mode": "write",
      "supports_json": true,
      "resource": "zap",
      "action_class": "write"
    }
  ]
}
