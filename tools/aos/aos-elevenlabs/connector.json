{
  "tool": "aos-elevenlabs",
  "backend": "elevenlabs-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "voice-generation",
    "surface": "tts-clone-sfx",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "worker_visible_actions": [
      "tts.generate",
      "tts.stream",
      "voices.list",
      "voices.get",
      "voices.clone",
      "sfx.generate",
      "audio.isolate",
      "history.list",
      "history.download",
      "model.list",
      "user.read"
    ],
    "fields": [
      {
        "id": "text",
        "label": "Text to Speak",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "rows": 4,
        "applies_to": ["tts.generate", "tts.stream"],
        "placeholder": "Hello, welcome to ElevenLabs text-to-speech.",
        "description": "The text content to convert to speech."
      },
      {
        "id": "voice_id",
        "label": "Voice ID",
        "type": "text",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["tts.generate", "tts.stream", "voices.get"],
        "placeholder": "21m00Tcm4TlvDq8ikWAM",
        "description": "ElevenLabs voice identifier. Use voices.list to discover available voices.",
        "example": "21m00Tcm4TlvDq8ikWAM"
      },
      {
        "id": "model_id",
        "label": "Model",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "placeholder": "eleven_multilingual_v2",
        "description": "ElevenLabs TTS model to use.",
        "options": [
          { "value": "eleven_monolingual_v1", "label": "Monolingual v1" },
          { "value": "eleven_multilingual_v1", "label": "Multilingual v1" },
          { "value": "eleven_multilingual_v2", "label": "Multilingual v2" },
          { "value": "eleven_turbo_v2_5", "label": "Turbo v2.5 (Fastest)" }
        ],
        "example": "eleven_multilingual_v2"
      },
      {
        "id": "stability",
        "label": "Stability (0-1)",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["tts.generate", "tts.stream"],
        "placeholder": "0.5",
        "description": "Voice stability parameter. Higher = more consistent. Range: 0.0-1.0"
      },
      {
        "id": "similarity_boost",
        "label": "Similarity Boost (0-1)",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["tts.generate", "tts.stream"],
        "placeholder": "0.75",
        "description": "How closely to match the original voice. Range: 0.0-1.0"
      },
      {
        "id": "style",
        "label": "Style (0-1)",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["tts.generate", "tts.stream"],
        "placeholder": "0",
        "description": "Add exaggeration to voice performance. Range: 0.0-1.0"
      },
      {
        "id": "sfx_prompt",
        "label": "Sound Effect Description",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "rows": 3,
        "applies_to": ["sfx.generate"],
        "placeholder": "A dog barking in the distance with birds chirping",
        "description": "Natural language description of the sound effect to generate."
      },
      {
        "id": "sfx_duration",
        "label": "SFX Duration (seconds)",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "applies_to": ["sfx.generate"],
        "placeholder": "5",
        "description": "Desired length of generated sound effect in seconds."
      },
      {
        "id": "clone_name",
        "label": "Clone Voice Name",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["voices.clone"],
        "placeholder": "My Custom Voice",
        "description": "Name for the cloned voice."
      },
      {
        "id": "clone_description",
        "label": "Clone Voice Description",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "rows": 2,
        "applies_to": ["voices.clone"],
        "placeholder": "A professional narrator with a warm tone",
        "description": "Optional description of the voice characteristics."
      },
      {
        "id": "clone_files",
        "label": "Audio Sample File Paths",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["voices.clone"],
        "placeholder": "/path/to/sample1.mp3,/path/to/sample2.mp3",
        "description": "Comma-separated paths to audio samples for voice cloning."
      },
      {
        "id": "output_path",
        "label": "Output Path",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "tts.generate",
          "tts.stream",
          "sfx.generate",
          "audio.isolate",
          "history.download"
        ],
        "placeholder": "artifacts/demo.mp3",
        "description": "Local file path where the audio output will be saved.",
        "example": "artifacts/demo.mp3"
      },
      {
        "id": "history_item_id",
        "label": "History Item ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["history.download"],
        "placeholder": "VW7YKqPnjY4h39yTbx2L",
        "description": "ID of a history item to download.",
        "example": "VW7YKqPnjY4h39yTbx2L"
      }
    ],
    "commandDefaults": {
      "voices.get": {
        "args": ["ELEVENLABS_VOICE_ID"]
      },
      "history.download": {
        "args": ["ELEVENLABS_HISTORY_ITEM_ID"]
      },
      "tts.generate": {
        "args": ["ELEVENLABS_VOICE_ID", "ELEVENLABS_MODEL_ID"]
      },
      "tts.stream": {
        "args": ["ELEVENLABS_VOICE_ID", "ELEVENLABS_MODEL_ID"]
      }
    }
  },
  "connector": {
    "label": "ElevenLabs",
    "category": "creative-media",
    "categories": ["creative-media", "audio-generation", "voice-infrastructure"],
    "resources": ["voice", "model", "history", "user", "audio", "sfx"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["ELEVENLABS_API_KEY"],
    "interactive_setup": [
      "Create an ElevenLabs API key for the target workspace or account.",
      "Add ELEVENLABS_API_KEY in API Keys before enabling live reads.",
      "Optional: set ELEVENLABS_BASE_URL only if you need a non-default ElevenLabs API host.",
      "Optional: pin ELEVENLABS_VOICE_ID, ELEVENLABS_MODEL_ID, and ELEVENLABS_HISTORY_ITEM_ID for worker defaults.",
      "Use tts.generate for text-to-speech; return inline base64 by default or pass --output to write an audio file.",
      "Use tts.stream for chunked streaming TTS output to a file.",
      "Use voices.clone with --file to create instant voice clones from audio samples.",
      "Use sfx.generate with a text prompt to create sound effects.",
      "Use audio.isolate to remove background noise from an audio file."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "user",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "user",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and ElevenLabs API readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "user",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "user",
      "action_class": "read"
    },
    {
      "id": "voices.list",
      "summary": "List ElevenLabs voices with optional search and pagination",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "voice",
      "action_class": "read"
    },
    {
      "id": "voices.get",
      "summary": "Get details for a single ElevenLabs voice",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "voice",
      "action_class": "read"
    },
    {
      "id": "voices.clone",
      "summary": "Create an instant voice clone from audio samples",
      "required_mode": "write",
      "supports_json": true,
      "resource": "voice",
      "action_class": "write"
    },
    {
      "id": "model.list",
      "summary": "List ElevenLabs models",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "model",
      "action_class": "read"
    },
    {
      "id": "history.list",
      "summary": "List generated speech history items",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "history",
      "action_class": "read"
    },
    {
      "id": "history.download",
      "summary": "Download audio from a history item",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "history",
      "action_class": "read"
    },
    {
      "id": "user.read",
      "summary": "Read ElevenLabs user and subscription info",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "user",
      "action_class": "read"
    },
    {
      "id": "tts.generate",
      "summary": "Generate speech from text (returns complete audio)",
      "required_mode": "write",
      "supports_json": true,
      "resource": "audio",
      "action_class": "write"
    },
    {
      "id": "tts.stream",
      "summary": "Stream speech from text (chunked output to file)",
      "required_mode": "write",
      "supports_json": true,
      "resource": "audio",
      "action_class": "write"
    },
    {
      "id": "sfx.generate",
      "summary": "Generate a sound effect from a text description",
      "required_mode": "write",
      "supports_json": true,
      "resource": "sfx",
      "action_class": "write"
    },
    {
      "id": "audio.isolate",
      "summary": "Remove background noise from an audio file",
      "required_mode": "write",
      "supports_json": true,
      "resource": "audio",
      "action_class": "write"
    }
  ]
}
