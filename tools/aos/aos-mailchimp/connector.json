{
  "tool": "aos-mailchimp",
  "backend": "mailchimp-marketing-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "email-marketing",
    "surface": "audience-campaign",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["account", "audience_id", "campaign_id", "member_email"],
    "worker_visible_actions": [
      "account.read",
      "audience.list",
      "audience.read",
      "member.list",
      "member.read",
      "campaign.list",
      "campaign.read",
      "report.list",
      "report.read"
    ],
    "fields": [
      {
        "id": "account",
        "label": "Server Prefix",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["account.read"],
        "placeholder": "us21",
        "description": "Mailchimp data center/server prefix. Usually inferred from the API key suffix, with MAILCHIMP_SERVER_PREFIX available as an override."
      },
      {
        "id": "audience_id",
        "label": "Audience ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["audience.read", "member.list", "member.read"],
        "placeholder": "a1b2c3d4e5",
        "description": "The Mailchimp audience/list ID to read members from."
      },
      {
        "id": "campaign_id",
        "label": "Campaign ID",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["campaign.read", "report.read"],
        "placeholder": "9f8e7d6c5b",
        "description": "The Mailchimp campaign ID to read or get reports for."
      },
      {
        "id": "member_email",
        "label": "Member email",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["member.read"],
        "placeholder": "contact@example.com",
        "description": "Email address of the audience member to read details for."
      }
    ],
    "commandDefaults": {
      "account.read": {
        "selection_surface": "account"
      },
      "audience.list": {
        "selection_surface": "audience",
        "limit": 10
      },
      "audience.read": {
        "selection_surface": "audience",
        "args": ["MAILCHIMP_AUDIENCE_ID"]
      },
      "member.list": {
        "selection_surface": "member",
        "args": ["MAILCHIMP_AUDIENCE_ID"],
        "limit": 10
      },
      "member.read": {
        "selection_surface": "member",
        "args": ["MAILCHIMP_AUDIENCE_ID", "MAILCHIMP_MEMBER_EMAIL"]
      },
      "campaign.list": {
        "selection_surface": "campaign",
        "limit": 10
      },
      "campaign.read": {
        "selection_surface": "campaign",
        "args": ["MAILCHIMP_CAMPAIGN_ID"]
      },
      "report.list": {
        "selection_surface": "campaign",
        "limit": 10
      },
      "report.read": {
        "selection_surface": "campaign",
        "args": ["MAILCHIMP_CAMPAIGN_ID"]
      }
    },
    "pickerHints": {
      "account": {
        "kind": "account",
        "selection_surface": "account",
        "resource": "mailchimp.account",
        "source_command": "account.read",
        "source_fields": ["account_name", "username", "email", "dc"]
      },
      "audience": {
        "kind": "audience",
        "selection_surface": "audience",
        "resource": "mailchimp.audience",
        "source_command": "audience.list",
        "source_fields": ["id", "name", "stats.member_count"]
      },
      "campaign": {
        "kind": "campaign",
        "selection_surface": "campaign",
        "resource": "mailchimp.campaign",
        "source_command": "campaign.list",
        "source_fields": ["id", "settings.title", "status", "emails_sent"]
      },
      "member": {
        "kind": "member",
        "selection_surface": "member",
        "resource": "mailchimp.member",
        "source_command": "member.list",
        "source_fields": ["id", "email_address", "status", "last_changed"]
      }
    }
  },
  "connector": {
    "label": "Mailchimp",
    "category": "marketing-publishing",
    "categories": ["marketing-publishing", "email-marketing", "crm-revenue"],
    "resources": ["account", "audience", "member", "campaign", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["MAILCHIMP_API_KEY", "MAILCHIMP_SERVER_PREFIX"],
    "interactive_setup": [
      "Create a Mailchimp Marketing API key for the target account.",
      "Preferred: add MAILCHIMP_API_KEY in API Keys; the connector resolves operator service keys first and falls back to process env only in its service-key helper.",
      "Optional: add MAILCHIMP_SERVER_PREFIX in API Keys only if you need to override the data center suffix embedded in the API key.",
      "Optional: add MAILCHIMP_AUDIENCE_ID, MAILCHIMP_CAMPAIGN_ID, and MAILCHIMP_MEMBER_EMAIL to pin worker scope.",
      "campaign.create_draft and member.upsert are scaffolded placeholders that return scaffold_write_only until Mailchimp write workflows are reviewed for approval and compliance requirements."
    ]
  },
  "commands": [
    {
      "id": "account.read",
      "summary": "Read Mailchimp account metadata",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "account",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "audience.list",
      "summary": "List Mailchimp audiences",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "audience",
      "action_class": "read"
    },
    {
      "id": "audience.read",
      "summary": "Read a Mailchimp audience",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "audience",
      "action_class": "read"
    },
    {
      "id": "member.list",
      "summary": "List members in a Mailchimp audience",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "member",
      "action_class": "read"
    },
    {
      "id": "member.read",
      "summary": "Read a Mailchimp audience member",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "member",
      "action_class": "read"
    },
    {
      "id": "campaign.list",
      "summary": "List Mailchimp campaigns",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "campaign",
      "action_class": "read"
    },
    {
      "id": "campaign.read",
      "summary": "Read a Mailchimp campaign",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "campaign",
      "action_class": "read"
    },
    {
      "id": "report.list",
      "summary": "List Mailchimp campaign reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.read",
      "summary": "Read a Mailchimp campaign report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "campaign.create_draft",
      "summary": "Scaffold placeholder for draft Mailchimp campaign creation",
      "required_mode": "write",
      "supports_json": true,
      "resource": "campaign",
      "action_class": "write"
    },
    {
      "id": "member.upsert",
      "summary": "Scaffold placeholder for Mailchimp audience member upsert",
      "required_mode": "write",
      "supports_json": true,
      "resource": "member",
      "action_class": "write"
    }
  ]
}
