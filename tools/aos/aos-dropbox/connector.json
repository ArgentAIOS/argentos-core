{
  "tool": "aos-dropbox",
  "backend": "dropbox-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "document-storage",
    "surface": "file-folder-share",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["path", "file_id", "query", "cursor", "shared_link_settings"],
    "worker_visible_actions": ["file.list", "file.get", "folder.list", "search.query"],
    "fields": [
      {
        "id": "path",
        "label": "Path",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Dropbox file or folder path",
        "placeholder": "/Documents/Reports/Q4.pdf",
        "applies_to": [
          "file.list",
          "file.get",
          "file.upload",
          "file.download",
          "file.delete",
          "file.move",
          "folder.list",
          "folder.create"
        ],
        "example": "/Documents/Reports/Q4.pdf"
      },
      {
        "id": "file_id",
        "label": "File ID",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Dropbox file ID (used for operations when path is unavailable)",
        "placeholder": "id:a4ayc_80_OEAAAAAAAAAXw",
        "applies_to": ["file.get", "file.download", "file.delete", "file.move"],
        "example": "id:a4ayc_80_OEAAAAAAAAAXw"
      },
      {
        "id": "query",
        "label": "Search query",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Search term for finding files in Dropbox",
        "placeholder": "quarterly budget",
        "applies_to": ["search.query"],
        "example": "quarterly budget"
      },
      {
        "id": "cursor",
        "label": "Pagination cursor",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Cursor token for paginated listing results",
        "placeholder": "ZtkX9_EHj3x7PMkVuFIhwKYXEpwpLwyxp9vMKomUhllil9q7eWiAu",
        "applies_to": ["file.list", "folder.list", "search.query"],
        "example": "ZtkX9_EHj3x7PMkVuFIhwKYXEpwpLwyxp9vMKomUhllil9q7eWiAu"
      },
      {
        "id": "shared_link_settings",
        "label": "Shared link settings",
        "type": "json",
        "renderAs": "json",
        "required": false,
        "expressionEnabled": true,
        "valueType": "json",
        "description": "JSON configuration for shared link visibility and access",
        "placeholder": "{\"requested_visibility\": \"public\", \"audience\": \"public\"}",
        "applies_to": ["share.create_link"],
        "example": "{\"requested_visibility\": \"public\", \"audience\": \"public\"}"
      }
    ],
    "commandDefaults": {
      "file.list": {
        "selection_surface": "file",
        "args": ["DROPBOX_PATH"],
        "limit": 25
      },
      "file.get": {
        "selection_surface": "file",
        "args": ["DROPBOX_FILE_ID"]
      },
      "file.upload": {
        "selection_surface": "file",
        "args": ["DROPBOX_PATH"]
      },
      "file.download": {
        "selection_surface": "file",
        "args": ["DROPBOX_FILE_ID"]
      },
      "file.delete": {
        "selection_surface": "file",
        "args": ["DROPBOX_PATH"]
      },
      "file.move": {
        "selection_surface": "file",
        "args": ["DROPBOX_PATH"]
      },
      "folder.list": {
        "selection_surface": "folder",
        "args": ["DROPBOX_PATH"],
        "limit": 25
      },
      "folder.create": {
        "selection_surface": "folder",
        "args": ["DROPBOX_PATH"]
      },
      "share.create_link": {
        "selection_surface": "share",
        "args": ["DROPBOX_PATH"],
        "settings": "DROPBOX_SHARED_LINK_SETTINGS"
      },
      "share.list": {
        "selection_surface": "share",
        "args": ["DROPBOX_PATH"]
      },
      "search.query": {
        "selection_surface": "file",
        "query": "DROPBOX_QUERY",
        "limit": 25
      }
    },
    "pickerHints": {
      "file": {
        "kind": "file",
        "selection_surface": "file",
        "resource": "dropbox.file",
        "source_command": "file.list",
        "source_fields": ["id", "name", "path_display", "size", "server_modified", "content_hash"]
      },
      "folder": {
        "kind": "folder",
        "selection_surface": "folder",
        "resource": "dropbox.folder",
        "source_command": "folder.list",
        "source_fields": ["id", "name", "path_display"]
      },
      "share": {
        "kind": "shared_link",
        "selection_surface": "share",
        "resource": "dropbox.shared_link",
        "source_command": "share.list",
        "source_fields": ["id", "url", "name", "path_lower", "visibility", "expires"]
      }
    }
  },
  "connector": {
    "label": "Dropbox",
    "category": "document-storage",
    "categories": ["document-storage", "productivity", "collaboration"],
    "resources": ["file", "folder", "share"]
  },
  "auth": {
    "kind": "oauth2",
    "required": true,
    "service_keys": ["DROPBOX_APP_KEY", "DROPBOX_APP_SECRET", "DROPBOX_REFRESH_TOKEN"],
    "interactive_setup": [
      "Create a Dropbox app at https://www.dropbox.com/developers/apps.",
      "Choose 'Scoped access' and select 'Full Dropbox' or 'App folder' access type.",
      "Add DROPBOX_APP_KEY, DROPBOX_APP_SECRET, and DROPBOX_REFRESH_TOKEN in API Keys.",
      "Required scopes: files.metadata.read, files.content.read for read-only; add files.content.write, sharing.write for write operations.",
      "Set DROPBOX_PATH to scope default listings to a specific folder path (optional).",
      "Cursor-based pagination: pass the cursor from a previous response to continue listing.",
      "The connector is live-read-first and will report API failures instead of masking them."
    ]
  },
  "commands": [
    {
      "id": "file.list",
      "summary": "List files in a Dropbox folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.get",
      "summary": "Get metadata for a Dropbox file",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.upload",
      "summary": "Upload a file to Dropbox",
      "required_mode": "write",
      "supports_json": true,
      "resource": "file",
      "action_class": "write"
    },
    {
      "id": "file.download",
      "summary": "Download a file from Dropbox",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.delete",
      "summary": "Delete a file from Dropbox",
      "required_mode": "write",
      "supports_json": true,
      "resource": "file",
      "action_class": "write"
    },
    {
      "id": "file.move",
      "summary": "Move a Dropbox file to a different path",
      "required_mode": "write",
      "supports_json": true,
      "resource": "file",
      "action_class": "write"
    },
    {
      "id": "folder.list",
      "summary": "List subfolders in a Dropbox folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "folder",
      "action_class": "read"
    },
    {
      "id": "folder.create",
      "summary": "Create a new folder in Dropbox",
      "required_mode": "write",
      "supports_json": true,
      "resource": "folder",
      "action_class": "write"
    },
    {
      "id": "share.create_link",
      "summary": "Create a shared link for a Dropbox file or folder",
      "required_mode": "write",
      "supports_json": true,
      "resource": "share",
      "action_class": "write"
    },
    {
      "id": "share.list",
      "summary": "List shared links for a Dropbox file or folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "share",
      "action_class": "read"
    },
    {
      "id": "search.query",
      "summary": "Search for files in Dropbox",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
