{
  "tool": "aos-holace",
  "backend": "holace-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "legal-practice",
    "surface": "case-client-document-billing",
    "scaffold_only": true,
    "live_backend_available": false,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["case_id", "client_id", "document_type", "attorney_id"],
    "worker_visible_actions": [
      "case.list",
      "case.get",
      "case.create",
      "case.update",
      "case.timeline",
      "client.list",
      "client.get",
      "client.create",
      "client.intake",
      "document.list",
      "document.get",
      "document.generate",
      "document.upload",
      "deadline.list",
      "deadline.create",
      "deadline.check_statute",
      "settlement.list",
      "settlement.get",
      "settlement.tracker",
      "billing.list",
      "billing.create_invoice",
      "communication.log",
      "communication.list",
      "report.case_status",
      "report.pipeline"
    ],
    "fields": [
      {
        "id": "case_id",
        "label": "Case ID",
        "required": false,
        "applies_to": [
          "case.get",
          "case.update",
          "case.timeline",
          "document.list",
          "deadline.list",
          "settlement.list",
          "communication.list"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "client_id",
        "label": "Client ID",
        "required": false,
        "applies_to": ["client.get", "client.intake", "case.create"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "document_type",
        "label": "Document Type",
        "required": false,
        "applies_to": ["document.generate"],
        "example": "demand_letter",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "attorney_id",
        "label": "Attorney",
        "required": false,
        "applies_to": ["case.list", "case.create", "report.case_status"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "case_type",
        "label": "Case Type",
        "required": false,
        "applies_to": ["case.create", "case.list"],
        "example": "personal_injury",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "statute_state",
        "label": "State (for statute lookup)",
        "required": false,
        "applies_to": ["deadline.check_statute"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      }
    ],
    "commandDefaults": {
      "case.list": {
        "selection_surface": "case",
        "limit": 25
      },
      "case.get": {
        "selection_surface": "case",
        "args": ["HOLACE_CASE_ID"]
      },
      "case.create": {
        "selection_surface": "case"
      },
      "case.update": {
        "selection_surface": "case",
        "args": ["HOLACE_CASE_ID"]
      },
      "case.timeline": {
        "selection_surface": "case",
        "args": ["HOLACE_CASE_ID"]
      },
      "client.list": {
        "selection_surface": "client",
        "limit": 50
      },
      "client.get": {
        "selection_surface": "client",
        "args": ["HOLACE_CLIENT_ID"]
      },
      "client.create": {
        "selection_surface": "client"
      },
      "client.intake": {
        "selection_surface": "client",
        "args": ["HOLACE_CLIENT_ID"]
      },
      "document.list": {
        "selection_surface": "document",
        "limit": 25
      },
      "document.get": {
        "selection_surface": "document",
        "args": ["HOLACE_DOCUMENT_ID"]
      },
      "document.generate": {
        "selection_surface": "document"
      },
      "document.upload": {
        "selection_surface": "document"
      },
      "deadline.list": {
        "selection_surface": "deadline",
        "limit": 20
      },
      "deadline.create": {
        "selection_surface": "deadline"
      },
      "deadline.check_statute": {
        "selection_surface": "deadline"
      },
      "settlement.list": {
        "selection_surface": "settlement",
        "limit": 10
      },
      "settlement.get": {
        "selection_surface": "settlement",
        "args": ["HOLACE_SETTLEMENT_ID"]
      },
      "settlement.tracker": {
        "selection_surface": "settlement"
      },
      "billing.list": {
        "selection_surface": "billing",
        "limit": 25
      },
      "billing.create_invoice": {
        "selection_surface": "billing"
      },
      "communication.log": {
        "selection_surface": "communication"
      },
      "communication.list": {
        "selection_surface": "communication",
        "limit": 25
      },
      "report.case_status": {
        "selection_surface": "report"
      },
      "report.pipeline": {
        "selection_surface": "report"
      }
    },
    "pickerHints": {
      "case": {
        "kind": "case",
        "selection_surface": "case",
        "resource": "holace.case",
        "source_command": "case.list",
        "source_fields": [
          "id",
          "title",
          "client_name",
          "case_type",
          "status",
          "attorney",
          "open_date"
        ]
      },
      "client": {
        "kind": "client",
        "selection_surface": "client",
        "resource": "holace.client",
        "source_command": "client.list",
        "source_fields": ["id", "name", "email", "phone", "intake_date", "case_count"]
      },
      "document": {
        "kind": "document",
        "selection_surface": "document",
        "resource": "holace.document",
        "source_command": "document.list",
        "source_fields": ["id", "title", "type", "case_id", "created", "status"]
      },
      "deadline": {
        "kind": "deadline",
        "selection_surface": "deadline",
        "resource": "holace.deadline",
        "source_command": "deadline.list",
        "source_fields": ["id", "title", "due_date", "case_id", "type", "status"]
      },
      "settlement": {
        "kind": "settlement",
        "selection_surface": "settlement",
        "resource": "holace.settlement",
        "source_command": "settlement.list",
        "source_fields": ["id", "case_id", "amount", "status", "date"]
      }
    }
  },
  "connector": {
    "label": "HoLaCe",
    "category": "legal-practice",
    "categories": ["legal-practice", "case-management", "personal-injury"],
    "resources": [
      "case",
      "client",
      "document",
      "deadline",
      "settlement",
      "billing",
      "communication",
      "report"
    ]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["HOLACE_API_KEY"],
    "interactive_setup": [
      "Create or retrieve your HoLaCe API key from the firm admin panel.",
      "Add HOLACE_API_KEY in API Keys before enabling live reads.",
      "Set HOLACE_ATTORNEY_ID to default attorney filters.",
      "Set HOLACE_CASE_ID to preselect a case scope.",
      "All read and write paths are live \u2014 this is a first-party connector."
    ]
  },
  "commands": [
    {
      "id": "case.list",
      "summary": "List cases",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "case.get",
      "summary": "Get case details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "case.create",
      "summary": "Create a new case",
      "required_mode": "write",
      "supports_json": true,
      "resource": "case",
      "action_class": "write"
    },
    {
      "id": "case.update",
      "summary": "Update case details",
      "required_mode": "write",
      "supports_json": true,
      "resource": "case",
      "action_class": "write"
    },
    {
      "id": "case.timeline",
      "summary": "Get the full timeline for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "client.list",
      "summary": "List clients",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "client",
      "action_class": "read"
    },
    {
      "id": "client.get",
      "summary": "Get client details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "client",
      "action_class": "read"
    },
    {
      "id": "client.create",
      "summary": "Create a new client record",
      "required_mode": "write",
      "supports_json": true,
      "resource": "client",
      "action_class": "write"
    },
    {
      "id": "client.intake",
      "summary": "Run the client intake workflow",
      "required_mode": "write",
      "supports_json": true,
      "resource": "client",
      "action_class": "write"
    },
    {
      "id": "document.list",
      "summary": "List documents for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "document",
      "action_class": "read"
    },
    {
      "id": "document.get",
      "summary": "Get a specific document",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "document",
      "action_class": "read"
    },
    {
      "id": "document.generate",
      "summary": "Generate a document from template (e.g. demand letter)",
      "required_mode": "write",
      "supports_json": true,
      "resource": "document",
      "action_class": "write"
    },
    {
      "id": "document.upload",
      "summary": "Upload a document to a case",
      "required_mode": "write",
      "supports_json": true,
      "resource": "document",
      "action_class": "write"
    },
    {
      "id": "deadline.list",
      "summary": "List deadlines and statute dates",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "deadline",
      "action_class": "read"
    },
    {
      "id": "deadline.create",
      "summary": "Create a deadline or reminder",
      "required_mode": "write",
      "supports_json": true,
      "resource": "deadline",
      "action_class": "write"
    },
    {
      "id": "deadline.check_statute",
      "summary": "Check statute of limitations for a state",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "deadline",
      "action_class": "read"
    },
    {
      "id": "settlement.list",
      "summary": "List settlements",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "settlement.get",
      "summary": "Get settlement details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "settlement.tracker",
      "summary": "View settlement pipeline tracker",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "billing.list",
      "summary": "List billing entries and invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "billing",
      "action_class": "read"
    },
    {
      "id": "billing.create_invoice",
      "summary": "Create an invoice for a case",
      "required_mode": "write",
      "supports_json": true,
      "resource": "billing",
      "action_class": "write"
    },
    {
      "id": "communication.log",
      "summary": "Log a client communication",
      "required_mode": "write",
      "supports_json": true,
      "resource": "communication",
      "action_class": "write"
    },
    {
      "id": "communication.list",
      "summary": "List communications for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "communication",
      "action_class": "read"
    },
    {
      "id": "report.case_status",
      "summary": "Generate case status report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.pipeline",
      "summary": "Generate case pipeline report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
