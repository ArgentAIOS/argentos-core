{
  "tool": "aos-holace",
  "backend": "holace-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "legal-practice",
    "surface": "case-client-document-billing",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": [
      "case_id",
      "client_id",
      "document_id",
      "settlement_id",
      "attorney_id",
      "case_type",
      "statute_state"
    ],
    "worker_visible_actions": [
      "case.list",
      "case.get",
      "case.timeline",
      "client.list",
      "client.get",
      "document.list",
      "document.get",
      "deadline.list",
      "deadline.check_statute",
      "settlement.list",
      "settlement.get",
      "settlement.tracker",
      "billing.list",
      "communication.list",
      "report.case_status",
      "report.pipeline"
    ],
    "fields": [
      {
        "id": "case_id",
        "label": "Case ID",
        "required": false,
        "applies_to": [
          "case.get",
          "case.timeline",
          "document.list",
          "deadline.list",
          "settlement.list",
          "billing.list",
          "communication.list",
          "report.case_status"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "HoLaCe case identifier. May be supplied by operator scope key HOLACE_CASE_ID."
      },
      {
        "id": "client_id",
        "label": "Client ID",
        "required": false,
        "applies_to": [
          "client.get",
          "case.list"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "HoLaCe client identifier. May be supplied by operator scope key HOLACE_CLIENT_ID."
      },
      {
        "id": "document_id",
        "label": "Document ID",
        "required": false,
        "applies_to": [
          "document.get"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "HoLaCe document identifier. May be supplied by operator scope key HOLACE_DOCUMENT_ID."
      },
      {
        "id": "settlement_id",
        "label": "Settlement ID",
        "required": false,
        "applies_to": [
          "settlement.get"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "HoLaCe settlement identifier. May be supplied by operator scope key HOLACE_SETTLEMENT_ID."
      },
      {
        "id": "attorney_id",
        "label": "Attorney",
        "required": false,
        "applies_to": [
          "case.list",
          "report.pipeline"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Attorney filter. May be supplied by operator scope key HOLACE_ATTORNEY_ID."
      },
      {
        "id": "case_type",
        "label": "Case Type",
        "required": false,
        "applies_to": [
          "case.list",
          "deadline.check_statute"
        ],
        "example": "personal_injury",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Case type filter or statute lookup context."
      },
      {
        "id": "statute_state",
        "label": "State",
        "required": false,
        "applies_to": [
          "deadline.check_statute"
        ],
        "example": "CA",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "US state code for statute-of-limitations lookup."
      }
    ],
    "commandDefaults": {
      "case.list": {
        "selection_surface": "case",
        "args": [
          "HOLACE_ATTORNEY_ID",
          "HOLACE_CLIENT_ID",
          "HOLACE_CASE_TYPE"
        ],
        "limit": 25
      },
      "case.get": {
        "selection_surface": "case",
        "args": [
          "HOLACE_CASE_ID"
        ]
      },
      "case.timeline": {
        "selection_surface": "case",
        "args": [
          "HOLACE_CASE_ID"
        ]
      },
      "client.list": {
        "selection_surface": "client",
        "limit": 50
      },
      "client.get": {
        "selection_surface": "client",
        "args": [
          "HOLACE_CLIENT_ID"
        ]
      },
      "document.list": {
        "selection_surface": "document",
        "args": [
          "HOLACE_CASE_ID"
        ],
        "limit": 25
      },
      "document.get": {
        "selection_surface": "document",
        "args": [
          "HOLACE_DOCUMENT_ID"
        ]
      },
      "deadline.list": {
        "selection_surface": "deadline",
        "args": [
          "HOLACE_CASE_ID"
        ],
        "limit": 20
      },
      "deadline.check_statute": {
        "selection_surface": "deadline",
        "args": [
          "HOLACE_STATUTE_STATE",
          "HOLACE_CASE_TYPE"
        ]
      },
      "settlement.list": {
        "selection_surface": "settlement",
        "args": [
          "HOLACE_CASE_ID"
        ],
        "limit": 10
      },
      "settlement.get": {
        "selection_surface": "settlement",
        "args": [
          "HOLACE_SETTLEMENT_ID"
        ]
      },
      "settlement.tracker": {
        "selection_surface": "settlement"
      },
      "billing.list": {
        "selection_surface": "billing",
        "args": [
          "HOLACE_CASE_ID"
        ],
        "limit": 25
      },
      "communication.list": {
        "selection_surface": "communication",
        "args": [
          "HOLACE_CASE_ID"
        ],
        "limit": 25
      },
      "report.case_status": {
        "selection_surface": "report",
        "args": [
          "HOLACE_CASE_ID"
        ]
      },
      "report.pipeline": {
        "selection_surface": "report",
        "args": [
          "HOLACE_ATTORNEY_ID"
        ]
      }
    },
    "pickerHints": {
      "case": {
        "kind": "case",
        "selection_surface": "case",
        "resource": "holace.case",
        "source_command": "case.list",
        "source_fields": [
          "id",
          "title",
          "client_name",
          "case_type",
          "status",
          "attorney",
          "open_date"
        ]
      },
      "client": {
        "kind": "client",
        "selection_surface": "client",
        "resource": "holace.client",
        "source_command": "client.list",
        "source_fields": [
          "id",
          "name",
          "email",
          "phone",
          "intake_date",
          "case_count"
        ]
      },
      "document": {
        "kind": "document",
        "selection_surface": "document",
        "resource": "holace.document",
        "source_command": "document.list",
        "source_fields": [
          "id",
          "title",
          "type",
          "case_id",
          "created",
          "status"
        ]
      },
      "deadline": {
        "kind": "deadline",
        "selection_surface": "deadline",
        "resource": "holace.deadline",
        "source_command": "deadline.list",
        "source_fields": [
          "id",
          "title",
          "due_date",
          "case_id",
          "type",
          "status"
        ]
      },
      "settlement": {
        "kind": "settlement",
        "selection_surface": "settlement",
        "resource": "holace.settlement",
        "source_command": "settlement.list",
        "source_fields": [
          "id",
          "case_id",
          "amount",
          "status",
          "date"
        ]
      }
    }
  },
  "connector": {
    "label": "HoLaCe",
    "category": "legal-practice",
    "categories": [
      "legal-practice",
      "case-management",
      "personal-injury"
    ],
    "resources": [
      "case",
      "client",
      "document",
      "deadline",
      "settlement",
      "billing",
      "communication",
      "report"
    ]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": [
      "HOLACE_API_KEY",
      "HOLACE_API_BASE_URL"
    ],
    "optional_scope_service_keys": [
      "HOLACE_ATTORNEY_ID",
      "HOLACE_CASE_ID",
      "HOLACE_CLIENT_ID",
      "HOLACE_DOCUMENT_ID",
      "HOLACE_SETTLEMENT_ID",
      "HOLACE_CASE_TYPE",
      "HOLACE_STATUTE_STATE"
    ],
    "interactive_setup": [
      "Add HOLACE_API_KEY in operator-controlled service keys before enabling live reads.",
      "Add HOLACE_API_BASE_URL in operator-controlled service keys for the firm HoLaCe API host.",
      "Optionally set HOLACE_ATTORNEY_ID, HOLACE_CASE_ID, HOLACE_CLIENT_ID, HOLACE_DOCUMENT_ID, HOLACE_SETTLEMENT_ID, HOLACE_CASE_TYPE, and HOLACE_STATUTE_STATE as operator scope defaults.",
      "Local HOLACE_* environment variables are only a development harness fallback.",
      "Write commands are not advertised until a write bridge is implemented and smoke-tested."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "case.list",
      "summary": "List cases",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "case.get",
      "summary": "Get case details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "case.timeline",
      "summary": "Get the timeline for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "case",
      "action_class": "read"
    },
    {
      "id": "client.list",
      "summary": "List clients",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "client",
      "action_class": "read"
    },
    {
      "id": "client.get",
      "summary": "Get client details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "client",
      "action_class": "read"
    },
    {
      "id": "document.list",
      "summary": "List documents for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "document",
      "action_class": "read"
    },
    {
      "id": "document.get",
      "summary": "Get a specific document",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "document",
      "action_class": "read"
    },
    {
      "id": "deadline.list",
      "summary": "List deadlines and statute dates",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "deadline",
      "action_class": "read"
    },
    {
      "id": "deadline.check_statute",
      "summary": "Check statute of limitations for a state",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "deadline",
      "action_class": "read"
    },
    {
      "id": "settlement.list",
      "summary": "List settlements",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "settlement.get",
      "summary": "Get settlement details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "settlement.tracker",
      "summary": "View settlement pipeline tracker",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "settlement",
      "action_class": "read"
    },
    {
      "id": "billing.list",
      "summary": "List billing entries and invoices",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "billing",
      "action_class": "read"
    },
    {
      "id": "communication.list",
      "summary": "List communications for a case",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "communication",
      "action_class": "read"
    },
    {
      "id": "report.case_status",
      "summary": "Generate case status report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.pipeline",
      "summary": "Generate pipeline report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    }
  ]
}
