{
  "tool": "aos-callscrub",
  "backend": "callscrub-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "sales-analytics",
    "surface": "call-transcript-coaching",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": [
      "call_id",
      "agent_name",
      "date_range",
      "team_id",
      "coaching_id",
      "search_query",
      "report_type"
    ],
    "worker_visible_actions": [
      "call.list",
      "call.get",
      "transcript.get",
      "transcript.search",
      "coaching.list",
      "coaching.get",
      "agent.list",
      "agent.stats",
      "agent.scorecard",
      "team.list",
      "team.stats",
      "report.list"
    ],
    "fields": [
      {
        "id": "call_id",
        "label": "Call ID",
        "required": false,
        "applies_to": ["call.get", "transcript.get"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "CallScrub call identifier. May be supplied by operator scope key CALLSCRUB_CALL_ID."
      },
      {
        "id": "agent_name",
        "label": "Sales Agent",
        "required": false,
        "applies_to": ["call.list", "agent.stats", "agent.scorecard"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Agent filter. May be supplied by operator scope key CALLSCRUB_AGENT_NAME."
      },
      {
        "id": "team_id",
        "label": "Team",
        "required": false,
        "applies_to": ["team.stats", "call.list"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Team filter. May be supplied by operator scope key CALLSCRUB_TEAM_ID."
      },
      {
        "id": "date_range",
        "label": "Date Range",
        "required": false,
        "applies_to": ["call.list", "agent.stats", "team.stats", "report.list"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "CallScrub date range expression such as last_7d or 2026-04-01..2026-04-07."
      },
      {
        "id": "coaching_id",
        "label": "Coaching Report ID",
        "required": false,
        "applies_to": ["coaching.get"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "CallScrub coaching report identifier."
      },
      {
        "id": "search_query",
        "label": "Search Query",
        "required": false,
        "applies_to": ["transcript.search"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Full-text transcript search query."
      },
      {
        "id": "report_type",
        "label": "Report Type",
        "required": false,
        "applies_to": ["report.list"],
        "example": "weekly_scorecard",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional report type filter."
      }
    ],
    "commandDefaults": {
      "call.list": {
        "selection_surface": "call",
        "args": ["CALLSCRUB_TEAM_ID", "CALLSCRUB_AGENT_NAME", "CALLSCRUB_DATE_RANGE"],
        "limit": 25
      },
      "call.get": {
        "selection_surface": "call",
        "args": ["CALLSCRUB_CALL_ID"]
      },
      "transcript.get": {
        "selection_surface": "transcript",
        "args": ["CALLSCRUB_CALL_ID"]
      },
      "transcript.search": {
        "selection_surface": "transcript",
        "args": ["CALLSCRUB_SEARCH_QUERY"],
        "limit": 20
      },
      "coaching.list": {
        "selection_surface": "coaching",
        "limit": 10
      },
      "coaching.get": {
        "selection_surface": "coaching",
        "args": ["CALLSCRUB_COACHING_ID"]
      },
      "agent.list": {
        "selection_surface": "agent",
        "limit": 50
      },
      "agent.stats": {
        "selection_surface": "agent",
        "args": ["CALLSCRUB_AGENT_NAME", "CALLSCRUB_DATE_RANGE"]
      },
      "agent.scorecard": {
        "selection_surface": "agent",
        "args": ["CALLSCRUB_AGENT_NAME"]
      },
      "team.list": {
        "selection_surface": "team",
        "limit": 20
      },
      "team.stats": {
        "selection_surface": "team",
        "args": ["CALLSCRUB_TEAM_ID", "CALLSCRUB_DATE_RANGE"]
      },
      "report.list": {
        "selection_surface": "report",
        "args": ["CALLSCRUB_REPORT_TYPE", "CALLSCRUB_DATE_RANGE"],
        "limit": 10
      }
    },
    "pickerHints": {
      "call": {
        "kind": "call",
        "selection_surface": "call",
        "resource": "callscrub.call",
        "source_command": "call.list",
        "source_fields": ["id", "agent_name", "duration", "date", "score", "disposition"]
      },
      "agent": {
        "kind": "agent",
        "selection_surface": "agent",
        "resource": "callscrub.agent",
        "source_command": "agent.list",
        "source_fields": ["id", "name", "team", "total_calls", "avg_score"]
      },
      "team": {
        "kind": "team",
        "selection_surface": "team",
        "resource": "callscrub.team",
        "source_command": "team.list",
        "source_fields": ["id", "name", "agent_count", "avg_score"]
      },
      "coaching": {
        "kind": "coaching",
        "selection_surface": "coaching",
        "resource": "callscrub.coaching",
        "source_command": "coaching.list",
        "source_fields": ["id", "call_id", "agent_name", "created", "summary"]
      }
    }
  },
  "connector": {
    "label": "CallScrub",
    "category": "sales-analytics",
    "categories": ["sales-analytics", "call-tracking", "coaching"],
    "resources": ["call", "transcript", "coaching", "agent", "team", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["CALLSCRUB_API_KEY", "CALLSCRUB_API_BASE_URL"],
    "optional_scope_service_keys": [
      "CALLSCRUB_TEAM_ID",
      "CALLSCRUB_AGENT_NAME",
      "CALLSCRUB_CALL_ID",
      "CALLSCRUB_COACHING_ID",
      "CALLSCRUB_DATE_RANGE",
      "CALLSCRUB_SEARCH_QUERY",
      "CALLSCRUB_REPORT_TYPE"
    ],
    "interactive_setup": [
      "Add CALLSCRUB_API_KEY in operator-controlled service keys before enabling live reads.",
      "Add CALLSCRUB_API_BASE_URL in operator-controlled service keys for the CallScrub API host.",
      "Optionally set CALLSCRUB_TEAM_ID, CALLSCRUB_AGENT_NAME, CALLSCRUB_CALL_ID, CALLSCRUB_COACHING_ID, CALLSCRUB_DATE_RANGE, CALLSCRUB_SEARCH_QUERY, and CALLSCRUB_REPORT_TYPE as operator scope defaults.",
      "Local CALLSCRUB_* environment variables are only a development harness fallback.",
      "Write commands are not advertised until a write bridge is implemented and smoke-tested."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "call.list",
      "summary": "List recorded sales calls",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "call.get",
      "summary": "Get details for a specific call",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "transcript.get",
      "summary": "Get the transcript for a call",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transcript",
      "action_class": "read"
    },
    {
      "id": "transcript.search",
      "summary": "Search across call transcripts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transcript",
      "action_class": "read"
    },
    {
      "id": "coaching.list",
      "summary": "List coaching reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "coaching",
      "action_class": "read"
    },
    {
      "id": "coaching.get",
      "summary": "Get a coaching report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "coaching",
      "action_class": "read"
    },
    {
      "id": "agent.list",
      "summary": "List sales agents",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "agent.stats",
      "summary": "Get performance stats for a sales agent",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "agent.scorecard",
      "summary": "Get the scorecard for a sales agent",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "team.list",
      "summary": "List sales teams",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "team.stats",
      "summary": "Get performance stats for a team",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "report.list",
      "summary": "List generated reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    }
  ]
}
