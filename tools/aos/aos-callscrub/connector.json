{
  "tool": "aos-callscrub",
  "backend": "callscrub-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "sales-analytics",
    "surface": "call-transcript-coaching",
    "scaffold_only": true,
    "live_backend_available": false,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["call_id", "agent_name", "date_range", "team_id"],
    "worker_visible_actions": [
      "call.list",
      "call.get",
      "call.upload",
      "call.analyze",
      "transcript.get",
      "transcript.search",
      "coaching.generate",
      "coaching.list",
      "coaching.get",
      "agent.list",
      "agent.stats",
      "agent.scorecard",
      "team.list",
      "team.stats",
      "report.generate",
      "report.list"
    ],
    "fields": [
      {
        "id": "call_id",
        "label": "Call ID",
        "required": false,
        "applies_to": ["call.get", "transcript.get", "coaching.generate"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "agent_name",
        "label": "Sales Agent",
        "required": false,
        "applies_to": ["call.list", "agent.stats", "agent.scorecard"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "team_id",
        "label": "Team",
        "required": false,
        "applies_to": ["team.stats", "call.list"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "date_range",
        "label": "Date Range",
        "required": false,
        "applies_to": ["call.list", "report.generate", "agent.stats"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "search_query",
        "label": "Search Query",
        "required": false,
        "applies_to": ["transcript.search"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "report_type",
        "label": "Report Type",
        "required": false,
        "applies_to": ["report.generate"],
        "example": "weekly_scorecard",
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      }
    ],
    "commandDefaults": {
      "call.list": {
        "selection_surface": "call",
        "limit": 25
      },
      "call.get": {
        "selection_surface": "call",
        "args": ["CALLSCRUB_CALL_ID"]
      },
      "call.analyze": {
        "selection_surface": "call",
        "args": ["CALLSCRUB_CALL_ID"]
      },
      "transcript.get": {
        "selection_surface": "transcript",
        "args": ["CALLSCRUB_CALL_ID"]
      },
      "transcript.search": {
        "selection_surface": "transcript",
        "limit": 20
      },
      "coaching.list": {
        "selection_surface": "coaching",
        "limit": 10
      },
      "coaching.get": {
        "selection_surface": "coaching",
        "args": ["CALLSCRUB_COACHING_ID"]
      },
      "agent.list": {
        "selection_surface": "agent",
        "limit": 50
      },
      "agent.stats": {
        "selection_surface": "agent",
        "args": ["CALLSCRUB_AGENT_NAME"]
      },
      "agent.scorecard": {
        "selection_surface": "agent",
        "args": ["CALLSCRUB_AGENT_NAME"]
      },
      "team.list": {
        "selection_surface": "team",
        "limit": 20
      },
      "team.stats": {
        "selection_surface": "team",
        "args": ["CALLSCRUB_TEAM_ID"]
      },
      "report.generate": {
        "selection_surface": "report"
      },
      "report.list": {
        "selection_surface": "report",
        "limit": 10
      }
    },
    "pickerHints": {
      "call": {
        "kind": "call",
        "selection_surface": "call",
        "resource": "callscrub.call",
        "source_command": "call.list",
        "source_fields": ["id", "agent_name", "duration", "date", "score", "disposition"]
      },
      "agent": {
        "kind": "agent",
        "selection_surface": "agent",
        "resource": "callscrub.agent",
        "source_command": "agent.list",
        "source_fields": ["id", "name", "team", "total_calls", "avg_score"]
      },
      "team": {
        "kind": "team",
        "selection_surface": "team",
        "resource": "callscrub.team",
        "source_command": "team.list",
        "source_fields": ["id", "name", "agent_count", "avg_score"]
      },
      "coaching": {
        "kind": "coaching",
        "selection_surface": "coaching",
        "resource": "callscrub.coaching",
        "source_command": "coaching.list",
        "source_fields": ["id", "call_id", "agent_name", "created", "summary"]
      }
    }
  },
  "connector": {
    "label": "CallScrub",
    "category": "sales-analytics",
    "categories": ["sales-analytics", "call-tracking", "coaching"],
    "resources": ["call", "transcript", "coaching", "agent", "team", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["CALLSCRUB_API_KEY"],
    "interactive_setup": [
      "Create or retrieve your CallScrub API key from the admin dashboard.",
      "Add CALLSCRUB_API_KEY in API Keys before enabling live reads.",
      "Set CALLSCRUB_TEAM_ID to scope queries to a specific team.",
      "Set CALLSCRUB_AGENT_NAME to default agent filters.",
      "All read and write paths are live \u2014 this is a first-party connector."
    ]
  },
  "commands": [
    {
      "id": "call.list",
      "summary": "List recorded sales calls",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "call.get",
      "summary": "Get details for a specific call",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "call.upload",
      "summary": "Upload a call recording for processing",
      "required_mode": "write",
      "supports_json": true,
      "resource": "call",
      "action_class": "write"
    },
    {
      "id": "call.analyze",
      "summary": "Trigger AI analysis on a call",
      "required_mode": "write",
      "supports_json": true,
      "resource": "call",
      "action_class": "write"
    },
    {
      "id": "transcript.get",
      "summary": "Get the transcript for a call",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transcript",
      "action_class": "read"
    },
    {
      "id": "transcript.search",
      "summary": "Search across all call transcripts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "transcript",
      "action_class": "read"
    },
    {
      "id": "coaching.generate",
      "summary": "Generate AI coaching recommendations for a call",
      "required_mode": "write",
      "supports_json": true,
      "resource": "coaching",
      "action_class": "write"
    },
    {
      "id": "coaching.list",
      "summary": "List coaching reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "coaching",
      "action_class": "read"
    },
    {
      "id": "coaching.get",
      "summary": "Get a specific coaching report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "coaching",
      "action_class": "read"
    },
    {
      "id": "agent.list",
      "summary": "List sales agents",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "agent.stats",
      "summary": "Get performance stats for a sales agent",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "agent.scorecard",
      "summary": "Get the full scorecard for a sales agent",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "agent",
      "action_class": "read"
    },
    {
      "id": "team.list",
      "summary": "List sales teams",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "team.stats",
      "summary": "Get performance stats for a team",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "team",
      "action_class": "read"
    },
    {
      "id": "report.generate",
      "summary": "Generate a performance report",
      "required_mode": "write",
      "supports_json": true,
      "resource": "report",
      "action_class": "write"
    },
    {
      "id": "report.list",
      "summary": "List generated reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
