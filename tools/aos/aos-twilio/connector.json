{
  "tool": "aos-twilio",
  "backend": "twilio-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "communications",
    "surface": "sms-voice-whatsapp",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["from_number", "to_number", "message", "voice_url"],
    "worker_visible_actions": [
      "sms.send",
      "sms.list",
      "sms.read",
      "call.create",
      "call.list",
      "call.status",
      "whatsapp.send",
      "whatsapp.list",
      "lookup.phone"
    ],
    "fields": [
      {
        "id": "from_number",
        "label": "From Number",
        "type": "select",
        "renderAs": "select",
        "required": true,
        "expressionEnabled": true,
        "pickerHint": "phone_number",
        "applies_to": ["sms.send", "call.create", "whatsapp.send"],
        "placeholder": "Select a Twilio number...",
        "description": "The Twilio phone number to send from (E.164 format, e.g. +17372046310)."
      },
      {
        "id": "to_number",
        "label": "To Number",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "applies_to": ["sms.send", "call.create", "whatsapp.send", "lookup.phone"],
        "placeholder": "+15551234567",
        "description": "Destination phone number in E.164 format."
      },
      {
        "id": "message",
        "label": "Message Body",
        "type": "richtext",
        "renderAs": "richtext",
        "required": true,
        "expressionEnabled": true,
        "rows": 4,
        "applies_to": ["sms.send", "whatsapp.send"],
        "placeholder": "Hello from ArgentOS!",
        "description": "The text body of the SMS or WhatsApp message. Max 1600 characters for SMS."
      },
      {
        "id": "media_url",
        "label": "Media URL",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "applies_to": ["sms.send", "whatsapp.send"],
        "placeholder": "https://example.com/image.jpg",
        "description": "URL of media to attach (MMS/WhatsApp). Twilio fetches from this URL."
      },
      {
        "id": "voice_action",
        "label": "Voice Action",
        "type": "select",
        "renderAs": "select",
        "required": true,
        "expressionEnabled": false,
        "applies_to": ["call.create"],
        "options": [
          {
            "value": "say",
            "label": "Say Text",
            "description": "Read text aloud using Twilio TTS"
          },
          {
            "value": "twiml_url",
            "label": "TwiML URL",
            "description": "Fetch TwiML instructions from a URL"
          },
          {
            "value": "twiml_inline",
            "label": "Inline TwiML",
            "description": "Provide raw TwiML XML directly"
          }
        ],
        "default": "say",
        "description": "How to handle the call once connected."
      },
      {
        "id": "say_text",
        "label": "Say Text",
        "type": "richtext",
        "renderAs": "richtext",
        "required": true,
        "expressionEnabled": true,
        "rows": 3,
        "applies_to": ["call.create"],
        "showWhen": { "field": "voice_action", "equals": "say" },
        "placeholder": "Hello, this is a call from ArgentOS.",
        "description": "Text to speak when the call connects. Uses Twilio TTS."
      },
      {
        "id": "voice_url",
        "label": "TwiML URL",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "applies_to": ["call.create"],
        "showWhen": { "field": "voice_action", "equals": "twiml_url" },
        "placeholder": "https://example.com/twiml.xml",
        "description": "URL returning TwiML instructions for call handling."
      },
      {
        "id": "twiml_inline",
        "label": "Inline TwiML",
        "type": "json",
        "renderAs": "json",
        "required": true,
        "expressionEnabled": true,
        "applies_to": ["call.create"],
        "showWhen": { "field": "voice_action", "equals": "twiml_inline" },
        "placeholder": "<Response><Say>Hello</Say></Response>",
        "description": "Raw TwiML XML to execute when the call connects."
      },
      {
        "id": "say_voice",
        "label": "Voice",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "applies_to": ["call.create"],
        "showWhen": { "field": "voice_action", "equals": "say" },
        "options": [
          { "value": "alice", "label": "Alice (female)" },
          { "value": "man", "label": "Man" },
          { "value": "woman", "label": "Woman" },
          { "value": "Polly.Joanna", "label": "Polly Joanna (neural)" },
          { "value": "Polly.Matthew", "label": "Polly Matthew (neural)" }
        ],
        "default": "alice",
        "description": "TTS voice for the Say verb."
      },
      {
        "id": "status_callback",
        "label": "Status Callback URL",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "applies_to": ["sms.send", "call.create"],
        "placeholder": "https://example.com/webhook/status",
        "description": "URL to receive delivery status webhooks (queued, sent, delivered, failed)."
      },
      {
        "id": "message_sid",
        "label": "Message SID",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "applies_to": ["sms.read"],
        "placeholder": "SMxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "description": "The unique SID of the message to retrieve."
      },
      {
        "id": "call_sid",
        "label": "Call SID",
        "type": "text",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "applies_to": ["call.status"],
        "placeholder": "CAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "description": "The unique SID of the call to check status for."
      },
      {
        "id": "options",
        "label": "Options",
        "type": "options_group",
        "applies_to": ["sms.send", "call.create", "whatsapp.send"],
        "children": [
          {
            "id": "max_price",
            "label": "Max Price (USD)",
            "type": "text",
            "renderAs": "text",
            "expressionEnabled": true,
            "placeholder": "0.05",
            "description": "Maximum price per message/minute. Twilio rejects if exceeded."
          },
          {
            "id": "validity_period",
            "label": "Validity Period (seconds)",
            "type": "text",
            "renderAs": "text",
            "expressionEnabled": true,
            "placeholder": "3600",
            "description": "How long Twilio will attempt delivery before giving up."
          }
        ]
      }
    ],
    "commandDefaults": {
      "sms.send": {
        "selection_surface": "sms",
        "args": ["TWILIO_FROM_NUMBER", "TWILIO_TO_NUMBER"],
        "message": "TWILIO_MESSAGE"
      },
      "sms.list": {
        "selection_surface": "sms",
        "limit": 20
      },
      "sms.read": {
        "selection_surface": "sms",
        "args": ["TWILIO_MESSAGE_SID"]
      },
      "call.create": {
        "selection_surface": "call",
        "args": ["TWILIO_FROM_NUMBER", "TWILIO_TO_NUMBER"],
        "voice_url": "TWILIO_VOICE_URL"
      },
      "call.list": {
        "selection_surface": "call",
        "limit": 20
      },
      "call.status": {
        "selection_surface": "call",
        "args": ["TWILIO_CALL_SID"]
      },
      "whatsapp.send": {
        "selection_surface": "whatsapp",
        "args": ["TWILIO_FROM_NUMBER", "TWILIO_TO_NUMBER"],
        "message": "TWILIO_MESSAGE"
      },
      "whatsapp.list": {
        "selection_surface": "whatsapp",
        "limit": 20
      },
      "lookup.phone": {
        "selection_surface": "lookup",
        "args": ["TWILIO_TO_NUMBER"]
      }
    },
    "pickerHints": {
      "sms": {
        "kind": "sms",
        "selection_surface": "sms",
        "resource": "twilio.message",
        "source_command": "sms.list",
        "source_fields": ["sid", "from", "to", "body", "status", "date_sent", "direction"]
      },
      "call": {
        "kind": "call",
        "selection_surface": "call",
        "resource": "twilio.call",
        "source_command": "call.list",
        "source_fields": ["sid", "from", "to", "status", "start_time", "duration", "direction"]
      },
      "whatsapp": {
        "kind": "whatsapp",
        "selection_surface": "whatsapp",
        "resource": "twilio.whatsapp_message",
        "source_command": "whatsapp.list",
        "source_fields": ["sid", "from", "to", "body", "status", "date_sent"]
      },
      "lookup": {
        "kind": "lookup",
        "selection_surface": "lookup",
        "resource": "twilio.phone_number",
        "source_command": "lookup.phone",
        "source_fields": ["phone_number", "country_code", "carrier", "caller_name", "line_type"]
      }
    }
  },
  "connector": {
    "label": "Twilio",
    "category": "communications",
    "categories": ["communications", "sms", "voice", "whatsapp"],
    "resources": ["sms", "call", "whatsapp", "lookup"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["TWILIO_ACCOUNT_SID", "TWILIO_AUTH_TOKEN"],
    "interactive_setup": [
      "Create or choose a Twilio Account SID and Auth Token from the Twilio Console.",
      "Add TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN in API Keys before enabling live reads.",
      "Set TWILIO_FROM_NUMBER to a Twilio phone number owned by the account (E.164 format, e.g. +17372046310).",
      "For WhatsApp, the from number must be a Twilio WhatsApp-enabled sender (e.g. +14155238886 sandbox).",
      "Optionally set TWILIO_TO_NUMBER and TWILIO_MESSAGE for default send scope.",
      "Optionally set TWILIO_STATUS_CALLBACK_URL to receive delivery webhooks.",
      "The connector supports live reads and writes for SMS, voice calls, and WhatsApp messages."
    ]
  },
  "events": [
    {
      "id": "sms.received",
      "resource": "sms",
      "summary": "Inbound SMS received",
      "delivery": "webhook",
      "configFields": [
        {
          "id": "event_from_filter",
          "label": "From Number Filter",
          "type": "text",
          "renderAs": "text",
          "required": false,
          "expressionEnabled": false,
          "placeholder": "+15551234567",
          "description": "Only trigger for messages from this number. Leave empty for all."
        },
        {
          "id": "event_to_number",
          "label": "To Number",
          "type": "select",
          "renderAs": "select",
          "required": false,
          "pickerHint": "phone_number",
          "description": "Only trigger for messages to this Twilio number. Leave empty for all."
        },
        {
          "id": "event_body_contains",
          "label": "Body Contains",
          "type": "text",
          "renderAs": "text",
          "required": false,
          "expressionEnabled": false,
          "placeholder": "STOP",
          "description": "Only trigger when message body contains this text (case-insensitive)."
        }
      ]
    },
    {
      "id": "call.completed",
      "resource": "call",
      "summary": "Voice call completed",
      "delivery": "webhook",
      "configFields": [
        {
          "id": "event_from_filter",
          "label": "From Number Filter",
          "type": "text",
          "renderAs": "text",
          "required": false,
          "expressionEnabled": false,
          "placeholder": "+15551234567",
          "description": "Only trigger for calls from this number. Leave empty for all."
        },
        {
          "id": "event_direction",
          "label": "Direction",
          "type": "select",
          "renderAs": "select",
          "required": false,
          "expressionEnabled": false,
          "options": [
            { "value": "any", "label": "Any direction" },
            { "value": "inbound", "label": "Inbound only" },
            { "value": "outbound", "label": "Outbound only" }
          ],
          "default": "any",
          "description": "Filter by call direction."
        },
        {
          "id": "event_min_duration",
          "label": "Minimum Duration (seconds)",
          "type": "text",
          "renderAs": "text",
          "required": false,
          "expressionEnabled": false,
          "placeholder": "10",
          "description": "Only trigger for calls lasting at least this many seconds."
        }
      ]
    }
  ],
  "commands": [
    {
      "id": "sms.send",
      "summary": "Send an SMS message",
      "required_mode": "write",
      "supports_json": true,
      "resource": "sms",
      "action_class": "write"
    },
    {
      "id": "sms.list",
      "summary": "List recent SMS messages",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "sms",
      "action_class": "read"
    },
    {
      "id": "sms.read",
      "summary": "Read an SMS message by SID",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "sms",
      "action_class": "read"
    },
    {
      "id": "call.create",
      "summary": "Create an outbound voice call",
      "required_mode": "write",
      "supports_json": true,
      "resource": "call",
      "action_class": "write"
    },
    {
      "id": "call.list",
      "summary": "List recent voice calls",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "call.status",
      "summary": "Get voice call status by SID",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "call",
      "action_class": "read"
    },
    {
      "id": "whatsapp.send",
      "summary": "Send a WhatsApp message",
      "required_mode": "write",
      "supports_json": true,
      "resource": "whatsapp",
      "action_class": "write"
    },
    {
      "id": "whatsapp.list",
      "summary": "List recent WhatsApp messages",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "whatsapp",
      "action_class": "read"
    },
    {
      "id": "lookup.phone",
      "summary": "Look up phone number carrier and caller info",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "lookup",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
