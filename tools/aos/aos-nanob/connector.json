{
  "tool": "aos-nanob",
  "backend": "google-genai",
  "manifest_schema_version": "1.0.0",
  "connector": {
    "label": "Gemini Image Studio",
    "category": "creative-media",
    "categories": ["creative-media", "image-generation", "marketing-creative"],
    "resources": ["image", "prompt", "session", "model"]
  },
  "scope": {
    "kind": "image-generation",
    "fields": [
      {
        "id": "prompt",
        "label": "Image Prompt",
        "type": "string",
        "renderAs": "richtext",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Detailed image generation prompt describing the desired image",
        "placeholder": "A serene landscape with mountains and a lake at sunset",
        "applies_to": ["generate", "edit"]
      },
      {
        "id": "model",
        "label": "Model",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Gemini image generation model to use",
        "options": [
          { "value": "gemini-2.0-flash", "label": "Gemini 2.0 Flash" },
          { "value": "gemini-pro-vision", "label": "Gemini Pro Vision" }
        ],
        "default": "gemini-2.0-flash",
        "applies_to": ["generate", "edit"]
      },
      {
        "id": "image_file",
        "label": "Source Image File",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Path or URL to image file for editing operations",
        "placeholder": "/path/to/image.jpg",
        "applies_to": ["edit"]
      },
      {
        "id": "num_images",
        "label": "Number of Images",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "description": "Number of images to generate (1-4)",
        "placeholder": "1",
        "default": 1,
        "applies_to": ["generate", "batch"]
      },
      {
        "id": "quality",
        "label": "Quality",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Image quality level",
        "options": [
          { "value": "standard", "label": "Standard" },
          { "value": "high", "label": "High Definition" }
        ],
        "default": "standard",
        "applies_to": ["generate", "edit"]
      },
      {
        "id": "session_name",
        "label": "Session Name",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Name to save or identify the generation session",
        "placeholder": "product-shots-2026",
        "applies_to": ["sessions.create"]
      },
      {
        "id": "batch_file",
        "label": "Batch File",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Path to file containing batch prompts (one per line)",
        "placeholder": "/path/to/prompts.txt",
        "applies_to": ["batch"]
      }
    ]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["GEMINI_API_KEY"],
    "interactive_setup": [
      "Add GEMINI_API_KEY in API Keys before enabling live image generation or edits.",
      "Install the Python harness in the connector's agent-harness directory with pip install -e .[dev].",
      "Use readonly mode for prompt building, model inspection, and session review; switch to write mode for image generation, edits, and batch runs."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and Gemini API readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "models",
      "summary": "List available Gemini image models",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "model",
      "action_class": "read"
    },
    {
      "id": "prompt",
      "summary": "Build or flatten an image-generation prompt",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "prompt",
      "action_class": "read"
    },
    {
      "id": "generate",
      "summary": "Generate one or more images from a prompt",
      "required_mode": "write",
      "supports_json": true,
      "resource": "image",
      "action_class": "write"
    },
    {
      "id": "edit",
      "summary": "Edit an existing image with a natural-language instruction",
      "required_mode": "write",
      "supports_json": true,
      "resource": "image",
      "action_class": "write"
    },
    {
      "id": "batch",
      "summary": "Run batch image generation from prompt files",
      "required_mode": "write",
      "supports_json": true,
      "resource": "image",
      "action_class": "write"
    },
    {
      "id": "sessions.list",
      "summary": "List saved image-generation sessions",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "session",
      "action_class": "read"
    },
    {
      "id": "sessions.create",
      "summary": "Create a new image-generation session",
      "required_mode": "write",
      "supports_json": true,
      "resource": "session",
      "action_class": "write"
    },
    {
      "id": "sessions.show",
      "summary": "Show a saved image-generation session",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "session",
      "action_class": "read"
    }
  ]
}
