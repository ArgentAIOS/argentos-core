{
  "backend": "microsoft-graph",
  "scope": {
    "kind": "productivity-suite",
    "surface": "mail-calendar-files-excel-teams",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["mailbox_id", "calendar_id", "team_id", "channel_id", "workbook_id"],
    "worker_visible_actions": [
      "mail.search",
      "mail.read",
      "mail.reply",
      "mail.send",
      "calendar.list",
      "calendar.create",
      "file.list",
      "excel.list_workbooks",
      "excel.list_worksheets",
      "excel.used_range",
      "excel.read_rows",
      "excel.append_rows",
      "teams.list_teams",
      "teams.list_channels",
      "teams.list_messages",
      "teams.reply_message"
    ],
    "fields": [
      {
        "id": "mailbox_id",
        "label": "Mailbox",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["mail.search", "mail.read", "mail.reply"],
        "placeholder": "user@company.com or ID...",
        "description": "Outlook mailbox to read from (email or ID)"
      },
      {
        "id": "message_id",
        "label": "Message",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["mail.read", "mail.reply"],
        "placeholder": "Message ID...",
        "description": "Message ID or identifier to operate on"
      },
      {
        "id": "search_query",
        "label": "Search Query",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["mail.search"],
        "placeholder": "from:sender subject:topic...",
        "description": "KQL search query for mail"
      },
      {
        "id": "calendar_id",
        "label": "Calendar",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["calendar.list", "calendar.create"],
        "placeholder": "Select calendar...",
        "description": "Outlook calendar ID to operate on"
      },
      {
        "id": "event_title",
        "label": "Event Title",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["calendar.create"],
        "placeholder": "Enter event title...",
        "description": "Title for the calendar event"
      },
      {
        "id": "event_start",
        "label": "Event Start",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "datetime",
        "applies_to": ["calendar.create"],
        "placeholder": "ISO 8601 datetime...",
        "description": "Start time in ISO 8601 format"
      },
      {
        "id": "team_id",
        "label": "Team",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["teams.list_channels", "teams.list_messages", "teams.reply_message"],
        "placeholder": "Select team...",
        "description": "Teams team ID to operate on"
      },
      {
        "id": "channel_id",
        "label": "Channel",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["teams.list_messages", "teams.reply_message"],
        "placeholder": "Select channel...",
        "description": "Teams channel ID to operate on"
      },
      {
        "id": "workbook_id",
        "label": "Workbook",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": [
          "excel.list_worksheets",
          "excel.used_range",
          "excel.read_rows",
          "excel.append_rows"
        ],
        "placeholder": "Select workbook...",
        "description": "Excel workbook ID to operate on"
      },
      {
        "id": "worksheet_id",
        "label": "Worksheet",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["excel.used_range", "excel.read_rows", "excel.append_rows"],
        "placeholder": "Select worksheet...",
        "description": "Excel worksheet ID to operate on"
      },
      {
        "id": "excel_data",
        "label": "Excel Data",
        "type": "json",
        "renderAs": "json",
        "required": false,
        "expressionEnabled": true,
        "valueType": "json",
        "applies_to": ["excel.append_rows"],
        "placeholder": "[[...]]",
        "description": "2D array of row data to append"
      }
    ]
  },
  "connector": {
    "label": "Microsoft 365",
    "category": "productivity-suite",
    "categories": ["productivity-suite", "inbox", "calendar", "files-docs"],
    "resources": ["mail", "calendar", "file", "excel", "teams"]
  },
  "auth": {
    "kind": "oauth-service-key",
    "required": true,
    "service_keys": ["M365_TENANT_ID", "M365_CLIENT_ID", "M365_CLIENT_SECRET"],
    "interactive_setup": [
      "Register an application in Microsoft Entra ID.",
      "Grant Microsoft Graph permissions for mail, calendar, files, Excel, and Teams as needed.",
      "Add M365_TENANT_ID, M365_CLIENT_ID, and M365_CLIENT_SECRET in API Keys.",
      "Use the live Teams and Excel picker commands to choose team, channel, workbook, worksheet, and range scope before going live."
    ]
  },
  "commands": [
    {
      "id": "health",
      "summary": "Report connector health and backend readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "mail.search",
      "summary": "Search Outlook mail in Microsoft Graph",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "mail",
      "action_class": "read"
    },
    {
      "id": "mail.read",
      "summary": "Read an Outlook message from Microsoft Graph",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "mail",
      "action_class": "read"
    },
    {
      "id": "mail.reply",
      "summary": "Reply to an Outlook message",
      "required_mode": "write",
      "supports_json": true,
      "resource": "mail",
      "action_class": "write"
    },
    {
      "id": "mail.send",
      "summary": "Send a new Outlook message",
      "required_mode": "write",
      "supports_json": true,
      "resource": "mail",
      "action_class": "write"
    },
    {
      "id": "calendar.list",
      "summary": "List calendar events from Microsoft Graph",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "calendar",
      "action_class": "read"
    },
    {
      "id": "calendar.create",
      "summary": "Create a calendar event",
      "required_mode": "write",
      "supports_json": true,
      "resource": "calendar",
      "action_class": "write"
    },
    {
      "id": "file.list",
      "summary": "List OneDrive or SharePoint files from Microsoft Graph",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "excel.list_workbooks",
      "summary": "List workbook candidates from OneDrive or SharePoint",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "excel",
      "action_class": "read"
    },
    {
      "id": "excel.list_worksheets",
      "summary": "List worksheets for a workbook",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "excel",
      "action_class": "read"
    },
    {
      "id": "excel.used_range",
      "summary": "Read the used range for a worksheet",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "excel",
      "action_class": "read"
    },
    {
      "id": "excel.read_rows",
      "summary": "Read Excel rows when workbook context is configured",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "excel",
      "action_class": "read"
    },
    {
      "id": "excel.append_rows",
      "summary": "Append Excel rows",
      "required_mode": "write",
      "supports_json": true,
      "resource": "excel",
      "action_class": "write"
    },
    {
      "id": "teams.list_messages",
      "summary": "List Teams channel messages when channel context is configured",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "teams",
      "action_class": "read"
    },
    {
      "id": "teams.list_teams",
      "summary": "List Teams teams available to the configured target user",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "teams",
      "action_class": "read"
    },
    {
      "id": "teams.list_channels",
      "summary": "List channels for a Teams team",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "teams",
      "action_class": "read"
    },
    {
      "id": "teams.reply_message",
      "summary": "Reply to a Teams message",
      "required_mode": "write",
      "supports_json": true,
      "resource": "teams",
      "action_class": "write"
    }
  ]
}
