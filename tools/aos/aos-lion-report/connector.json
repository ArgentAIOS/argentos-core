{
  "tool": "aos-lion-report",
  "backend": "lion-report-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "intelligence-reporting",
    "surface": "report-data-analysis",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["report_id", "report_type", "date_range", "data_source"],
    "worker_visible_actions": [
      "report.list",
      "report.get",
      "report.generate",
      "report.schedule",
      "data.list_sources",
      "data.query",
      "data.import",
      "analysis.run",
      "analysis.list",
      "template.list",
      "template.get",
      "export.pdf",
      "export.csv",
      "export.email"
    ],
    "fields": [
      {
        "id": "report_id",
        "label": "Report ID",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "report_type",
        "label": "Report Type",
        "required": false,
        "applies_to": ["report.generate", "report.list"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "date_range",
        "label": "Date Range",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "data_source",
        "label": "Data Source",
        "required": false,
        "applies_to": ["data.query", "data.import"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "template_id",
        "label": "Template",
        "required": false,
        "applies_to": ["report.generate"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "recipient_email",
        "label": "Email Recipient",
        "required": false,
        "applies_to": ["export.email"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      }
    ],
    "commandDefaults": {
      "report.list": {
        "selection_surface": "report",
        "limit": 25
      },
      "report.get": {
        "selection_surface": "report",
        "args": ["LION_REPORT_ID"]
      },
      "report.generate": {
        "selection_surface": "report"
      },
      "report.schedule": {
        "selection_surface": "report"
      },
      "data.list_sources": {
        "selection_surface": "data_source",
        "limit": 50
      },
      "data.query": {
        "selection_surface": "data_source",
        "args": ["LION_DATA_SOURCE"]
      },
      "data.import": {
        "selection_surface": "data_source"
      },
      "analysis.run": {
        "selection_surface": "analysis"
      },
      "analysis.list": {
        "selection_surface": "analysis",
        "limit": 20
      },
      "template.list": {
        "selection_surface": "template",
        "limit": 20
      },
      "template.get": {
        "selection_surface": "template",
        "args": ["LION_TEMPLATE_ID"]
      },
      "export.pdf": {
        "selection_surface": "export",
        "args": ["LION_REPORT_ID"]
      },
      "export.csv": {
        "selection_surface": "export",
        "args": ["LION_REPORT_ID"]
      },
      "export.email": {
        "selection_surface": "export",
        "args": ["LION_REPORT_ID"]
      }
    },
    "pickerHints": {
      "report": {
        "kind": "report",
        "selection_surface": "report",
        "resource": "lion.report",
        "source_command": "report.list",
        "source_fields": ["id", "title", "type", "status", "created", "updated"]
      },
      "data_source": {
        "kind": "data_source",
        "selection_surface": "data_source",
        "resource": "lion.data_source",
        "source_command": "data.list_sources",
        "source_fields": ["id", "name", "type", "last_sync", "record_count"]
      },
      "analysis": {
        "kind": "analysis",
        "selection_surface": "analysis",
        "resource": "lion.analysis",
        "source_command": "analysis.list",
        "source_fields": ["id", "report_id", "type", "status", "created"]
      },
      "template": {
        "kind": "template",
        "selection_surface": "template",
        "resource": "lion.template",
        "source_command": "template.list",
        "source_fields": ["id", "name", "description", "category"]
      }
    }
  },
  "connector": {
    "label": "LION Report",
    "category": "intelligence-reporting",
    "categories": ["intelligence-reporting", "data-analysis", "business-intelligence"],
    "resources": ["report", "data_source", "analysis", "template", "export"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["LION_REPORT_API_KEY"],
    "interactive_setup": [
      "Create or retrieve your LION Report / VaultLion API key from the admin panel.",
      "Add LION_REPORT_API_KEY in API Keys before enabling live reads.",
      "Set LION_DATA_SOURCE to default data source filters.",
      "Set LION_TEMPLATE_ID to preselect a report template.",
      "All read and write paths are live \u2014 this is a first-party connector."
    ]
  },
  "commands": [
    {
      "id": "report.list",
      "summary": "List intelligence reports",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.get",
      "summary": "Get a specific report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.generate",
      "summary": "Generate a new intelligence report",
      "required_mode": "write",
      "supports_json": true,
      "resource": "report",
      "action_class": "write"
    },
    {
      "id": "report.schedule",
      "summary": "Schedule a recurring report",
      "required_mode": "write",
      "supports_json": true,
      "resource": "report",
      "action_class": "write"
    },
    {
      "id": "data.list_sources",
      "summary": "List available data sources",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "data_source",
      "action_class": "read"
    },
    {
      "id": "data.query",
      "summary": "Query a data source",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "data_source",
      "action_class": "read"
    },
    {
      "id": "data.import",
      "summary": "Import data from an external source",
      "required_mode": "write",
      "supports_json": true,
      "resource": "data_source",
      "action_class": "write"
    },
    {
      "id": "analysis.run",
      "summary": "Run an analysis on report data",
      "required_mode": "write",
      "supports_json": true,
      "resource": "analysis",
      "action_class": "write"
    },
    {
      "id": "analysis.list",
      "summary": "List completed analyses",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "analysis",
      "action_class": "read"
    },
    {
      "id": "template.list",
      "summary": "List report templates",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "template",
      "action_class": "read"
    },
    {
      "id": "template.get",
      "summary": "Get a report template",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "template",
      "action_class": "read"
    },
    {
      "id": "export.pdf",
      "summary": "Export a report as PDF",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "export.csv",
      "summary": "Export report data as CSV",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "export.email",
      "summary": "Email a report to a recipient",
      "required_mode": "write",
      "supports_json": true,
      "resource": "export",
      "action_class": "write"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
