{
  "tool": "aos-paypunch",
  "backend": "paypunch-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "time-tracking",
    "surface": "timesheet-employee-export",
    "scaffold_only": true,
    "live_backend_available": false,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["tenant_id", "company_id", "employee_id", "pay_period"],
    "worker_visible_actions": [
      "timesheet.list",
      "timesheet.get",
      "timesheet.approve",
      "timesheet.reject",
      "employee.list",
      "employee.get",
      "employee.create",
      "company.list",
      "company.get",
      "export.quickbooks_iif",
      "export.csv",
      "pay_period.list",
      "pay_period.current",
      "report.hours_summary",
      "report.overtime"
    ],
    "fields": [
      {
        "id": "tenant_id",
        "label": "Bookkeeper Tenant",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "company_id",
        "label": "Client Company",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "employee_id",
        "label": "Employee",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "pay_period",
        "label": "Pay Period",
        "required": false,
        "applies_to": ["timesheet.list", "export.quickbooks_iif", "report.hours_summary"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      },
      {
        "id": "export_format",
        "label": "Export Format",
        "required": false,
        "applies_to": ["export.quickbooks_iif", "export.csv"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": ""
      }
    ],
    "commandDefaults": {
      "timesheet.list": {
        "selection_surface": "timesheet",
        "limit": 50
      },
      "timesheet.get": {
        "selection_surface": "timesheet",
        "args": ["PAYPUNCH_TIMESHEET_ID"]
      },
      "timesheet.approve": {
        "selection_surface": "timesheet",
        "args": ["PAYPUNCH_TIMESHEET_ID"]
      },
      "timesheet.reject": {
        "selection_surface": "timesheet",
        "args": ["PAYPUNCH_TIMESHEET_ID"]
      },
      "employee.list": {
        "selection_surface": "employee",
        "limit": 100
      },
      "employee.get": {
        "selection_surface": "employee",
        "args": ["PAYPUNCH_EMPLOYEE_ID"]
      },
      "employee.create": {
        "selection_surface": "employee"
      },
      "company.list": {
        "selection_surface": "company",
        "limit": 50
      },
      "company.get": {
        "selection_surface": "company",
        "args": ["PAYPUNCH_COMPANY_ID"]
      },
      "export.quickbooks_iif": {
        "selection_surface": "export"
      },
      "export.csv": {
        "selection_surface": "export"
      },
      "pay_period.list": {
        "selection_surface": "pay_period",
        "limit": 12
      },
      "pay_period.current": {
        "selection_surface": "pay_period"
      },
      "report.hours_summary": {
        "selection_surface": "report"
      },
      "report.overtime": {
        "selection_surface": "report"
      }
    },
    "pickerHints": {
      "timesheet": {
        "kind": "timesheet",
        "selection_surface": "timesheet",
        "resource": "paypunch.timesheet",
        "source_command": "timesheet.list",
        "source_fields": ["id", "employee_name", "date", "hours", "status", "company"]
      },
      "employee": {
        "kind": "employee",
        "selection_surface": "employee",
        "resource": "paypunch.employee",
        "source_command": "employee.list",
        "source_fields": ["id", "name", "company", "role", "status"]
      },
      "company": {
        "kind": "company",
        "selection_surface": "company",
        "resource": "paypunch.company",
        "source_command": "company.list",
        "source_fields": ["id", "name", "employee_count", "pay_schedule"]
      },
      "pay_period": {
        "kind": "pay_period",
        "selection_surface": "pay_period",
        "resource": "paypunch.pay_period",
        "source_command": "pay_period.list",
        "source_fields": ["id", "start_date", "end_date", "status", "company"]
      }
    }
  },
  "connector": {
    "label": "PayPunch",
    "category": "time-tracking",
    "categories": ["time-tracking", "payroll", "bookkeeping"],
    "resources": ["timesheet", "employee", "company", "pay_period", "export", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["PAYPUNCH_API_KEY"],
    "interactive_setup": [
      "Create or retrieve your PayPunch API key from the bookkeeper admin panel.",
      "Add PAYPUNCH_API_KEY in API Keys before enabling live reads.",
      "Set PAYPUNCH_TENANT_ID to scope to a specific bookkeeper tenant.",
      "Set PAYPUNCH_COMPANY_ID to default company filters.",
      "All read and write paths are live \u2014 this is a first-party connector."
    ]
  },
  "commands": [
    {
      "id": "timesheet.list",
      "summary": "List timesheets",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "read"
    },
    {
      "id": "timesheet.get",
      "summary": "Get a specific timesheet entry",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "read"
    },
    {
      "id": "timesheet.approve",
      "summary": "Approve a timesheet for payroll",
      "required_mode": "write",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "write"
    },
    {
      "id": "timesheet.reject",
      "summary": "Reject a timesheet with reason",
      "required_mode": "write",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "write"
    },
    {
      "id": "employee.list",
      "summary": "List employees",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "employee",
      "action_class": "read"
    },
    {
      "id": "employee.get",
      "summary": "Get employee details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "employee",
      "action_class": "read"
    },
    {
      "id": "employee.create",
      "summary": "Create a new employee",
      "required_mode": "write",
      "supports_json": true,
      "resource": "employee",
      "action_class": "write"
    },
    {
      "id": "company.list",
      "summary": "List client companies",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "company",
      "action_class": "read"
    },
    {
      "id": "company.get",
      "summary": "Get company details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "company",
      "action_class": "read"
    },
    {
      "id": "export.quickbooks_iif",
      "summary": "Export timesheet data as QuickBooks IIF",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "export.csv",
      "summary": "Export timesheet data as CSV",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "pay_period.list",
      "summary": "List pay periods",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "pay_period",
      "action_class": "read"
    },
    {
      "id": "pay_period.current",
      "summary": "Get the current active pay period",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "pay_period",
      "action_class": "read"
    },
    {
      "id": "report.hours_summary",
      "summary": "Generate hours summary report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.overtime",
      "summary": "Generate overtime report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
