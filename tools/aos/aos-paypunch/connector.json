{
  "tool": "aos-paypunch",
  "backend": "paypunch-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "time-tracking",
    "surface": "timesheet-employee-export",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["tenant_id", "company_id", "employee_id", "timesheet_id", "pay_period"],
    "worker_visible_actions": [
      "timesheet.list",
      "timesheet.get",
      "employee.list",
      "employee.get",
      "company.list",
      "company.get",
      "export.quickbooks_iif",
      "export.csv",
      "pay_period.list",
      "pay_period.current",
      "report.hours_summary",
      "report.overtime"
    ],
    "fields": [
      {
        "id": "tenant_id",
        "label": "Bookkeeper Tenant",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional operator service-key default PAYPUNCH_TENANT_ID."
      },
      {
        "id": "company_id",
        "label": "Client Company",
        "required": false,
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional operator service-key default PAYPUNCH_COMPANY_ID."
      },
      {
        "id": "employee_id",
        "label": "Employee",
        "required": false,
        "applies_to": ["timesheet.list", "employee.get"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional operator service-key default PAYPUNCH_EMPLOYEE_ID."
      },
      {
        "id": "timesheet_id",
        "label": "Timesheet",
        "required": false,
        "applies_to": ["timesheet.get"],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional operator service-key default PAYPUNCH_TIMESHEET_ID."
      },
      {
        "id": "pay_period",
        "label": "Pay Period",
        "required": false,
        "applies_to": [
          "timesheet.list",
          "export.quickbooks_iif",
          "export.csv",
          "report.hours_summary",
          "report.overtime"
        ],
        "renderAs": "text",
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Optional operator service-key default PAYPUNCH_PAY_PERIOD."
      }
    ],
    "commandDefaults": {
      "timesheet.list": {
        "selection_surface": "timesheet",
        "args": ["PAYPUNCH_TENANT_ID", "PAYPUNCH_COMPANY_ID", "PAYPUNCH_EMPLOYEE_ID", "PAYPUNCH_PAY_PERIOD"],
        "limit": 50
      },
      "timesheet.get": {
        "selection_surface": "timesheet",
        "args": ["PAYPUNCH_TIMESHEET_ID"]
      },
      "employee.list": {
        "selection_surface": "employee",
        "args": ["PAYPUNCH_COMPANY_ID"],
        "limit": 100
      },
      "employee.get": {
        "selection_surface": "employee",
        "args": ["PAYPUNCH_EMPLOYEE_ID"]
      },
      "company.list": {
        "selection_surface": "company",
        "args": ["PAYPUNCH_TENANT_ID"],
        "limit": 50
      },
      "company.get": {
        "selection_surface": "company",
        "args": ["PAYPUNCH_COMPANY_ID"]
      },
      "export.quickbooks_iif": {
        "selection_surface": "export",
        "args": ["PAYPUNCH_COMPANY_ID", "PAYPUNCH_PAY_PERIOD"]
      },
      "export.csv": {
        "selection_surface": "export",
        "args": ["PAYPUNCH_COMPANY_ID", "PAYPUNCH_PAY_PERIOD"]
      },
      "pay_period.list": {
        "selection_surface": "pay_period",
        "args": ["PAYPUNCH_COMPANY_ID"],
        "limit": 12
      },
      "pay_period.current": {
        "selection_surface": "pay_period",
        "args": ["PAYPUNCH_COMPANY_ID"]
      },
      "report.hours_summary": {
        "selection_surface": "report",
        "args": ["PAYPUNCH_COMPANY_ID", "PAYPUNCH_PAY_PERIOD"]
      },
      "report.overtime": {
        "selection_surface": "report",
        "args": ["PAYPUNCH_COMPANY_ID", "PAYPUNCH_PAY_PERIOD"]
      }
    },
    "pickerHints": {
      "timesheet": {
        "kind": "timesheet",
        "selection_surface": "timesheet",
        "resource": "paypunch.timesheet",
        "source_command": "timesheet.list",
        "source_fields": ["id", "employee_name", "date", "hours", "status", "company"]
      },
      "employee": {
        "kind": "employee",
        "selection_surface": "employee",
        "resource": "paypunch.employee",
        "source_command": "employee.list",
        "source_fields": ["id", "name", "company", "role", "status"]
      },
      "company": {
        "kind": "company",
        "selection_surface": "company",
        "resource": "paypunch.company",
        "source_command": "company.list",
        "source_fields": ["id", "name", "employee_count", "pay_schedule"]
      },
      "pay_period": {
        "kind": "pay_period",
        "selection_surface": "pay_period",
        "resource": "paypunch.pay_period",
        "source_command": "pay_period.list",
        "source_fields": ["id", "start_date", "end_date", "status", "company"]
      }
    }
  },
  "connector": {
    "label": "PayPunch",
    "category": "time-tracking",
    "categories": ["time-tracking", "payroll", "bookkeeping"],
    "resources": ["timesheet", "employee", "company", "pay_period", "export", "report"]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["PAYPUNCH_API_KEY", "PAYPUNCH_API_BASE_URL"],
    "optional_scope_service_keys": [
      "PAYPUNCH_TENANT_ID",
      "PAYPUNCH_COMPANY_ID",
      "PAYPUNCH_EMPLOYEE_ID",
      "PAYPUNCH_TIMESHEET_ID",
      "PAYPUNCH_PAY_PERIOD"
    ],
    "interactive_setup": [
      "Create or retrieve a PayPunch API key from the bookkeeper admin panel.",
      "Add PAYPUNCH_API_KEY in operator-controlled service keys before enabling live reads.",
      "Add PAYPUNCH_API_BASE_URL in operator-controlled service keys for the PayPunch API host.",
      "Optionally set PAYPUNCH_TENANT_ID, PAYPUNCH_COMPANY_ID, PAYPUNCH_EMPLOYEE_ID, PAYPUNCH_TIMESHEET_ID, and PAYPUNCH_PAY_PERIOD as operator-controlled scope defaults.",
      "This connector is live read-only. Do not advertise PayPunch write actions until a write bridge is implemented and verified."
    ]
  },
  "commands": [
    {
      "id": "timesheet.list",
      "summary": "List timesheets",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "read"
    },
    {
      "id": "timesheet.get",
      "summary": "Get a specific timesheet entry",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "timesheet",
      "action_class": "read"
    },
    {
      "id": "employee.list",
      "summary": "List employees",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "employee",
      "action_class": "read"
    },
    {
      "id": "employee.get",
      "summary": "Get employee details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "employee",
      "action_class": "read"
    },
    {
      "id": "company.list",
      "summary": "List client companies",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "company",
      "action_class": "read"
    },
    {
      "id": "company.get",
      "summary": "Get company details",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "company",
      "action_class": "read"
    },
    {
      "id": "export.quickbooks_iif",
      "summary": "Read a QuickBooks IIF export payload",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "export.csv",
      "summary": "Read a CSV export payload",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "export",
      "action_class": "read"
    },
    {
      "id": "pay_period.list",
      "summary": "List pay periods",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "pay_period",
      "action_class": "read"
    },
    {
      "id": "pay_period.current",
      "summary": "Get the current active pay period",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "pay_period",
      "action_class": "read"
    },
    {
      "id": "report.hours_summary",
      "summary": "Read an hours summary report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "report.overtime",
      "summary": "Read an overtime report",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "report",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
