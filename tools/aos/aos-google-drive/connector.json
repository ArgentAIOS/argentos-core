{
  "tool": "aos-google-drive",
  "backend": "google-drive-api",
  "manifest_schema_version": "1.0.0",
  "scope": {
    "kind": "document-storage",
    "surface": "file-folder-share",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": false,
    "workerFields": ["folder_id", "file_id", "mime_type", "query"],
    "worker_visible_actions": [
      "file.list",
      "file.get",
      "folder.list",
      "share.list",
      "export.pdf",
      "export.docx",
      "search.query"
    ],
    "fields": [
      {
        "id": "file_id",
        "label": "File ID",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Google Drive file ID for file operations",
        "placeholder": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms",
        "applies_to": ["file.get", "share.list", "export.pdf", "export.docx"],
        "example": "1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms"
      },
      {
        "id": "folder_id",
        "label": "Folder ID",
        "type": "string",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Google Drive folder ID for listing files or folders",
        "placeholder": "0BwwA4oUTeiV1TGRPeTVjaWRDY1E",
        "applies_to": ["file.list", "folder.list"],
        "example": "0BwwA4oUTeiV1TGRPeTVjaWRDY1E"
      },
      {
        "id": "mime_type",
        "label": "MIME type",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "File MIME type for filtering lists",
        "placeholder": "application/pdf",
        "options": [
          {
            "value": "application/pdf",
            "label": "PDF"
          },
          {
            "value": "application/vnd.google-apps.document",
            "label": "Google Docs"
          },
          {
            "value": "application/vnd.google-apps.spreadsheet",
            "label": "Google Sheets"
          },
          {
            "value": "application/vnd.google-apps.presentation",
            "label": "Google Slides"
          },
          {
            "value": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "label": "Word (DOCX)"
          },
          {
            "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "label": "Excel (XLSX)"
          },
          {
            "value": "text/plain",
            "label": "Text"
          }
        ],
        "applies_to": ["file.list"],
        "example": "application/vnd.google-apps.document"
      },
      {
        "id": "query",
        "label": "Search query",
        "type": "string",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Google Drive search query (supports operators like name contains, mimeType)",
        "placeholder": "name contains 'budget' and mimeType = 'application/pdf'",
        "applies_to": ["search.query"],
        "example": "name contains 'budget' and mimeType = 'application/pdf'"
      }
    ],
    "commandDefaults": {
      "file.list": {
        "selection_surface": "file",
        "args": ["GOOGLE_DRIVE_FOLDER_ID", "GOOGLE_DRIVE_MIME_TYPE"],
        "limit": 25
      },
      "file.get": {
        "selection_surface": "file",
        "args": ["GOOGLE_DRIVE_FILE_ID"]
      },
      "folder.list": {
        "selection_surface": "folder",
        "args": ["GOOGLE_DRIVE_FOLDER_ID"],
        "limit": 25
      },
      "share.list": {
        "selection_surface": "share",
        "args": ["GOOGLE_DRIVE_FILE_ID"]
      },
      "export.pdf": {
        "selection_surface": "file",
        "args": ["GOOGLE_DRIVE_FILE_ID"]
      },
      "export.docx": {
        "selection_surface": "file",
        "args": ["GOOGLE_DRIVE_FILE_ID"]
      },
      "search.query": {
        "selection_surface": "file",
        "args": ["GOOGLE_DRIVE_QUERY"],
        "limit": 25
      }
    },
    "pickerHints": {
      "file": {
        "kind": "file",
        "selection_surface": "file",
        "resource": "google-drive.file",
        "source_command": "file.list",
        "source_fields": ["id", "name", "mimeType", "size", "modifiedTime", "owners"]
      },
      "folder": {
        "kind": "folder",
        "selection_surface": "folder",
        "resource": "google-drive.folder",
        "source_command": "folder.list",
        "source_fields": ["id", "name", "modifiedTime", "owners"]
      },
      "share": {
        "kind": "permission",
        "selection_surface": "share",
        "resource": "google-drive.permission",
        "source_command": "share.list",
        "source_fields": ["id", "type", "role", "emailAddress", "displayName"]
      }
    }
  },
  "connector": {
    "label": "Google Drive",
    "category": "document-storage",
    "categories": ["document-storage", "productivity", "collaboration"],
    "resources": ["file", "folder", "share"]
  },
  "auth": {
    "kind": "oauth2",
    "required": true,
    "service_keys": [
      "GOOGLE_DRIVE_CLIENT_ID",
      "GOOGLE_DRIVE_CLIENT_SECRET",
      "GOOGLE_DRIVE_REFRESH_TOKEN",
      "GOOGLE_DRIVE_FOLDER_ID",
      "GOOGLE_DRIVE_FILE_ID",
      "GOOGLE_DRIVE_MIME_TYPE",
      "GOOGLE_DRIVE_QUERY",
      "GOOGLE_DRIVE_BASE_URL"
    ],
    "interactive_setup": [
      "Create a Google Cloud OAuth app with Drive API read/export scopes and obtain a refresh token.",
      "Add GOOGLE_DRIVE_CLIENT_ID, GOOGLE_DRIVE_CLIENT_SECRET, and GOOGLE_DRIVE_REFRESH_TOKEN in operator-controlled API Keys before enabling live reads.",
      "Optional linking keys such as GOOGLE_DRIVE_FOLDER_ID, GOOGLE_DRIVE_FILE_ID, GOOGLE_DRIVE_MIME_TYPE, and GOOGLE_DRIVE_QUERY are also resolved from operator-controlled API Keys first.",
      "No Google Drive write command is advertised until live write workflows and approval policy are implemented.",
      "The connector is live-read-first and will report API failures instead of masking them."
    ]
  },
  "commands": [
    {
      "id": "file.list",
      "summary": "List files in a Google Drive folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "file.get",
      "summary": "Get metadata for a Google Drive file",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "folder.list",
      "summary": "List subfolders in a Google Drive folder",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "folder",
      "action_class": "read"
    },
    {
      "id": "share.list",
      "summary": "List permissions on a Google Drive file",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "share",
      "action_class": "read"
    },
    {
      "id": "export.pdf",
      "summary": "Export a Google Workspace file as PDF",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "export.docx",
      "summary": "Export a Google Workspace file as DOCX",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "search.query",
      "summary": "Search for files in Google Drive",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "file",
      "action_class": "read"
    },
    {
      "id": "capabilities",
      "summary": "Describe the connector manifest",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted connector configuration",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Report connector health and setup readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run connector diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "connector",
      "action_class": "read"
    }
  ]
}
