{
  "tool": "aos-linear",
  "backend": "linear",
  "manifest_schema_version": "1.0.0",
  "connector": {
    "label": "Linear",
    "category": "project-management",
    "categories": ["project-management", "issue-tracking", "workflow"],
    "resources": ["issues", "projects", "workflow-states"]
  },
  "delivery_model": "poll",
  "risk_tier": "bounded-write",
  "scope": {
    "kind": "issue-tracking",
    "surface": "project-issue-state",
    "scaffold_only": false,
    "live_backend_available": true,
    "live_read_available": true,
    "write_bridge_available": true,
    "workerFields": ["team_id", "project_id", "issue_id", "status_id", "assignee_id"],
    "worker_visible_actions": [
      "list-projects",
      "list-issues",
      "create-issue",
      "update-issue",
      "search"
    ],
    "fields": [
      {
        "id": "team_id",
        "label": "Team",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select team...",
        "description": "Linear team to scope operations to (default: WEB)"
      },
      {
        "id": "project_id",
        "label": "Project",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select project...",
        "description": "Linear project ID or key to filter issues by"
      },
      {
        "id": "issue_id",
        "label": "Issue",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "placeholder": "Select issue...",
        "description": "Linear issue ID or key to operate on"
      },
      {
        "id": "title",
        "label": "Title",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["create-issue", "update-issue"],
        "placeholder": "Enter issue title...",
        "description": "The title of the issue"
      },
      {
        "id": "description",
        "label": "Description",
        "type": "richtext",
        "renderAs": "richtext",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["create-issue", "update-issue"],
        "placeholder": "Enter issue description...",
        "description": "Detailed description of the issue"
      },
      {
        "id": "status_id",
        "label": "Status",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["update-issue"],
        "options": [
          { "value": "backlog", "label": "Backlog" },
          { "value": "todo", "label": "Todo" },
          { "value": "in_progress", "label": "In Progress" },
          { "value": "in_review", "label": "In Review" },
          { "value": "done", "label": "Done" },
          { "value": "cancelled", "label": "Cancelled" }
        ],
        "description": "The workflow state of the issue"
      },
      {
        "id": "assignee_id",
        "label": "Assignee",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["create-issue", "update-issue"],
        "placeholder": "Email or user ID...",
        "description": "Team member to assign the issue to"
      },
      {
        "id": "priority",
        "label": "Priority",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "applies_to": ["create-issue", "update-issue"],
        "options": [
          { "value": "0", "label": "No priority" },
          { "value": "1", "label": "Urgent" },
          { "value": "2", "label": "High" },
          { "value": "3", "label": "Medium" },
          { "value": "4", "label": "Low" }
        ],
        "description": "Priority level of the issue"
      },
      {
        "id": "search_query",
        "label": "Search Query",
        "type": "text",
        "renderAs": "text",
        "required": false,
        "expressionEnabled": true,
        "valueType": "string",
        "applies_to": ["search"],
        "placeholder": "Search terms...",
        "description": "Text search query to find issues"
      }
    ]
  },
  "auth": {
    "kind": "service-key",
    "required": true,
    "service_keys": ["LINEAR_API_KEY"],
    "interactive_setup": [
      "Add LINEAR_API_KEY in ArgentOS API Keys.",
      "Optionally set LINEAR_TEAM_KEY if you want to override the default WEB team scope.",
      "This connector talks to Linear GraphQL at https://api.linear.app/graphql using the service key resolved from ArgentOS service keys first, then process.env."
    ]
  },
  "commands": [
    {
      "id": "capabilities",
      "summary": "List connector capabilities",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "projects",
      "action_class": "read"
    },
    {
      "id": "health",
      "summary": "Check Linear runtime readiness",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "projects",
      "action_class": "read"
    },
    {
      "id": "doctor",
      "summary": "Run Linear runtime diagnostics",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "projects",
      "action_class": "read"
    },
    {
      "id": "config.show",
      "summary": "Show redacted Linear connector config",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "projects",
      "action_class": "read"
    },
    {
      "id": "list-projects",
      "summary": "List Linear projects with issue counts",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "projects",
      "action_class": "read"
    },
    {
      "id": "list-issues",
      "summary": "List Linear issues with project, status, or assignee filters",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "issues",
      "action_class": "read"
    },
    {
      "id": "create-issue",
      "summary": "Create a Linear issue",
      "required_mode": "write",
      "supports_json": true,
      "resource": "issues",
      "action_class": "write"
    },
    {
      "id": "update-issue",
      "summary": "Update a Linear issue",
      "required_mode": "write",
      "supports_json": true,
      "resource": "issues",
      "action_class": "write"
    },
    {
      "id": "search",
      "summary": "Search Linear issues",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "issues",
      "action_class": "read"
    },
    {
      "id": "get-issue",
      "summary": "Get a Linear issue by identifier",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "issues",
      "action_class": "read"
    }
  ]
}
