{
  "tool": "aos-google",
  "backend": "gws",
  "manifest_schema_version": "1.0.0",
  "connector": {
    "label": "Google Workspace",
    "category": "inbox",
    "categories": ["inbox", "files-docs", "calendar"],
    "resources": ["gmail", "drive", "calendar"]
  },
  "scope": {
    "kind": "google-workspace",
    "workerFields": ["account", "query", "num_results", "language", "safe_search"],
    "fields": [
      {
        "id": "query",
        "label": "Search Query",
        "type": "string",
        "renderAs": "text",
        "required": true,
        "expressionEnabled": true,
        "valueType": "string",
        "description": "Search query for Google Search",
        "placeholder": "machine learning articles",
        "applies_to": ["gmail.search", "drive.list"]
      },
      {
        "id": "num_results",
        "label": "Number of Results",
        "type": "number",
        "renderAs": "number",
        "required": false,
        "expressionEnabled": true,
        "valueType": "number",
        "description": "Maximum number of results to return",
        "placeholder": "10",
        "default": 10,
        "applies_to": ["gmail.search", "drive.list", "calendar.list"]
      },
      {
        "id": "language",
        "label": "Language",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Language code for search results filtering",
        "options": [
          { "value": "en", "label": "English" },
          { "value": "es", "label": "Spanish" },
          { "value": "fr", "label": "French" },
          { "value": "de", "label": "German" },
          { "value": "it", "label": "Italian" },
          { "value": "ja", "label": "Japanese" },
          { "value": "zh", "label": "Chinese" }
        ],
        "default": "en",
        "applies_to": ["gmail.search"]
      },
      {
        "id": "safe_search",
        "label": "Safe Search",
        "type": "select",
        "renderAs": "select",
        "required": false,
        "expressionEnabled": false,
        "valueType": "string",
        "description": "Content filtering level for search results",
        "options": [
          { "value": "off", "label": "Off" },
          { "value": "moderate", "label": "Moderate" },
          { "value": "strict", "label": "Strict" }
        ],
        "default": "moderate",
        "applies_to": ["gmail.search"]
      }
    ],
    "commandDefaults": {
      "config.show": {
        "selection_surface": "account"
      },
      "gmail.search": {
        "selection_surface": "mailbox",
        "query": "newer_than:7d",
        "max_results": 10
      },
      "gmail.read": {
        "selection_surface": "message",
        "format": "full"
      },
      "drive.list": {
        "selection_surface": "file",
        "page_size": 10
      },
      "calendar.list": {
        "selection_surface": "event",
        "calendar_id": "primary",
        "max_results": 10
      },
      "calendar.create": {
        "selection_surface": "calendar",
        "calendar_id": "primary"
      }
    },
    "pickerHints": {
      "account": {
        "kind": "account",
        "selection_surface": "account",
        "items": [
          {
            "value": "me",
            "label": "Current Google account",
            "resource": "gmail.mailbox"
          }
        ]
      },
      "gmail_label": {
        "kind": "label",
        "selection_surface": "label",
        "resource": "gmail.label",
        "source_command": "gmail.users.labels.list",
        "source_fields": [
          "id",
          "name",
          "type",
          "labelListVisibility",
          "messagesTotal",
          "messagesUnread"
        ]
      },
      "calendar": {
        "kind": "calendar",
        "selection_surface": "calendar",
        "resource": "calendar.calendar",
        "source_command": "calendar.calendarList.list",
        "source_fields": ["id", "summary", "primary", "selected", "accessRole"]
      }
    }
  },
  "auth": {
    "kind": "oauth-local",
    "required": true,
    "interactive_setup": [
      "Install the upstream Google Workspace CLI (`gws`).",
      "Configure a Google OAuth client with `gws auth setup --login` or place client_secret.json in ~/.config/gws.",
      "Run `gws auth login -s drive,gmail,calendar,sheets,docs`.",
      "Optional: configure Model Armor env vars for sanitize-by-default."
    ]
  },
  "commands": [
    {
      "id": "gmail.search",
      "summary": "Search Gmail messages",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "gmail",
      "action_class": "read"
    },
    {
      "id": "gmail.read",
      "summary": "Read a Gmail message",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "gmail",
      "action_class": "read"
    },
    {
      "id": "drive.list",
      "summary": "List Drive files",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "drive",
      "action_class": "read"
    },
    {
      "id": "calendar.list",
      "summary": "List calendar events",
      "required_mode": "readonly",
      "supports_json": true,
      "resource": "calendar",
      "action_class": "read"
    },
    {
      "id": "calendar.create",
      "summary": "Create a calendar event",
      "required_mode": "write",
      "supports_json": true,
      "resource": "calendar",
      "action_class": "write"
    }
  ]
}
